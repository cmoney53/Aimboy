--[[
    CASHMERE SKIN THIEF - HIGH COMPATIBILITY
    Theme: Neon Green / Cashmere
    Features: Manual Asset Cloning, Draggable, Minimize, Auto-Refresh
--]]

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- 1. CLEANUP
if PlayerGui:FindFirstChild("CashmereSkinThief") then
    PlayerGui.CashmereSkinThief:Destroy()
end

-- 2. UI CREATION
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "CashmereSkinThief"
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Name = "MainFrame"
Main.Size = UDim2.new(0, 220, 0, 320)
Main.Position = UDim2.new(0.5, -110, 0.5, -160)
Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true 

local Corner = Instance.new("UICorner", Main)
Corner.CornerRadius = UDim.new(0, 10)

local Stroke = Instance.new("UIStroke", Main)
Stroke.Thickness = 2.5
Stroke.Color = Color3.fromRGB(50, 255, 50) -- Neon Green

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.Text = "CASHMERE"
Title.TextColor3 = Color3.fromRGB(50, 255, 50)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18

local MinBtn = Instance.new("TextButton", Main)
MinBtn.Size = UDim2.new(0, 30, 0, 30)
MinBtn.Position = UDim2.new(1, -35, 0, 5)
MinBtn.BackgroundTransparency = 1
MinBtn.Text = "−"
MinBtn.TextColor3 = Color3.fromRGB(50, 255, 50)
MinBtn.TextSize = 25

local Scroll = Instance.new("ScrollingFrame", Main)
Scroll.Size = UDim2.new(0.9, 0, 0.75, 0)
Scroll.Position = UDim2.new(0.05, 0, 0.15, 0)
Scroll.BackgroundTransparency = 1
Scroll.ScrollBarThickness = 2
Scroll.ScrollBarImageColor3 = Color3.fromRGB(50, 255, 50)
Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)

local Layout = Instance.new("UIListLayout", Scroll)
Layout.Padding = UDim.new(0, 5)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

-- 3. THE "THIEF" ENGINE (Manual Cloning)
local function stealSkin(targetPlayer)
    local myChar = LocalPlayer.Character
    local targetChar = targetPlayer.Character
    
    if myChar and targetChar then
        -- Clear current appearance
        for _, item in pairs(myChar:GetChildren()) do
            if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") or item:IsA("ShirtGraphic") then
                item:Destroy()
            end
        end
        
        -- Clone Body Colors & Clothing
        for _, item in pairs(targetChar:GetChildren()) do
            if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") or item:IsA("ShirtGraphic") then
                item:Clone().Parent = myChar
            end
        end
        
        -- Clone Accessories (Hairs, Hats, Back items)
        for _, item in pairs(targetChar:GetChildren()) do
            if item:IsA("Accessory") then
                local clone = item:Clone()
                clone.Parent = myChar
            end
        end
        
        -- Sync Face
        if targetChar:FindFirstChild("Head") and targetChar.Head:FindFirstChild("face") then
            if myChar:FindFirstChild("Head") then
                if myChar.Head:FindFirstChild("face") then myChar.Head.face:Destroy() end
                targetChar.Head.face:Clone().Parent = myChar.Head
            end
        end
    end
end

-- 4. UI LIST LOGIC
local function refresh()
    for _, item in pairs(Scroll:GetChildren()) do
        if item:IsA("TextButton") then item:Destroy() end
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton", Scroll)
            btn.Size = UDim2.new(1, -10, 0, 32)
            btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            btn.Text = p.DisplayName or p.Name
            btn.TextColor3 = Color3.white
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 13
            
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
            
            btn.MouseButton1Click:Connect(function()
                stealSkin(p)
            end)
        end
    end
    Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
end

-- 5. MINIMIZE LOGIC
local isMin = false
MinBtn.MouseButton1Click:Connect(function()
    isMin = not isMin
    Scroll.Visible = not isMin
    Main:TweenSize(isMin and UDim2.new(0, 220, 0, 40) or UDim2.new(0, 220, 0, 320), "Out", "Quad", 0.3, true)
    MinBtn.Text = isMin and "+" or "−"
end)

-- 6. INITIALIZE
refresh()
Players.PlayerAdded:Connect(refresh)
Players.PlayerRemoving:Connect(refresh)

print("Cashmere Skin Thief Loaded.")

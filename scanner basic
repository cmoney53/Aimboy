-- THE ULTRA SCAN FUNCTION
local function runUltraScan()
    ultraExecRegistry  = {}
    ultraAdminRegistry = {}
    ultraMoneyRegistry = {}
    ultraAllRegistry   = {}
    ultraSeenIds       = {}
    ultraScanCount     = 0
    clearUltraList()
    ultraProgressLabel.Text = "SCANNING... please wait"
    ultraProgressLabel.TextColor3 = Color3.fromRGB(255,60,255)

    local function ultraDeep(parent)
        local ok, children = pcall(function() return parent:GetChildren() end)
        if not ok then return end
        for _, child in ipairs(children) do
            ultraScanCount = ultraScanCount + 1
            if ultraScanCount % 20 == 0 then
                ultraProgressLabel.Text = "Scanned: " .. ultraScanCount .. " objects..."
                task.wait()
            end

            local id = ""
            pcall(function() id = child:GetFullName() end)
            if id == "" then id = tostring(child) end

            local isFireable = child:IsA("RemoteEvent") or child:IsA("RemoteFunction")
                or child:IsA("BindableEvent") or child:IsA("BindableFunction")

            if isFireable and not ultraSeenIds[id] then
                ultraSeenIds[id] = true

                local tag = "REMOTE"
                if child:IsA("RemoteEvent")    then tag = "RE"
                elseif child:IsA("RemoteFunction") then tag = "RF"
                elseif child:IsA("BindableEvent")  then tag = "BIND:E"
                elseif child:IsA("BindableFunction") then tag = "BIND:F" end

                local es = scoreKeywords(child.Name, execKeywords)
                local as = scoreKeywords(child.Name, ultraAdminKeywords)
                local ms = scoreKeywords(child.Name, ultraMoneyKeywords)

                -- Also score the parent name for extra signal
                pcall(function()
                    if child.Parent then
                        es = es + scoreKeywords(child.Parent.Name, execKeywords)  * 0.5
                        as = as + scoreKeywords(child.Parent.Name, ultraAdminKeywords) * 0.5
                        ms = ms + scoreKeywords(child.Parent.Name, ultraMoneyKeywords) * 0.5
                    end
                end)
                es = math.floor(es)
                as = math.floor(as)
                ms = math.floor(ms)

                local entry = {obj=child, tag=tag, es=es, as=as, ms=ms, bs=0}

                if es > 0 then table.insert(ultraExecRegistry,  entry) end
                if as > 0 then table.insert(ultraAdminRegistry, entry) end
                if ms > 0 then table.insert(ultraMoneyRegistry, entry) end
                table.insert(ultraAllRegistry, entry)
            end

            -- Recurse (skip terrain and player chars to keep it fast)
            if not child:IsA("Terrain") and not child:IsA("Player") then
                pcall(function() ultraDeep(child) end)
            end
        end
    end

    -- Scan every service
    local scanned = {}
    for _, svcName in ipairs(ultraServices) do
        pcall(function()
            local svc = game:GetService(svcName)
            if svc and not scanned[tostring(svc)] then
                scanned[tostring(svc)] = true
                ultraDeep(svc)
            end
        end)
    end
    -- Catch any root-level children not yet scanned
    pcall(function()
        for _, child in ipairs(game:GetChildren()) do
            if not scanned[tostring(child)] then
                scanned[tostring(child)] = true
                pcall(function() ultraDeep(child) end)
            end
        end
    end)

    -- Summary
    local execC  = #ultraExecRegistry
    local adminC = #ultraAdminRegistry
    local moneyC = #ultraMoneyRegistry
    local allC   = #ultraAllRegistry
    ultraProgressLabel.Text = string.format(
        "DONE  Objects:%d  ALL:%d  EXEC:%d  ADMIN:%d  MONEY:%d",
        ultraScanCount, allC, execC, adminC, moneyC)
    ultraProgressLabel.TextColor3 = Color3.fromRGB(57,255,20)
    logOutput(string.format("ULTRA SCAN COMPLETE — %d remotes | EXEC:%d ADMIN:%d MONEY:%d",
        allC, execC, adminC, moneyC), Color3.fromRGB(255,60,255))

    showUltraTab(ultraActiveTab)
end


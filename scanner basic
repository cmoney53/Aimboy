local mt = getrawmetatable and getrawmetatable(game)
if mt then
    setreadonly(mt, false)
    local oldNamecall = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if method == "FireServer" or method == "InvokeServer" then
            task.spawn(snifferLog, self, args)
        end
        return oldNamecall(self, ...)
    end)
end

-- 7. OPTIMIZED ENGINE (NO REBUILD SPAM)
local collapsed = {}
local entryCache = {}

local function createEntry(obj, typeTag, category)
    local id = obj:GetFullName()
    if entryCache[id] then 
        entryCache[id].Visible = not collapsed[category] 
        return 
    end

    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  ↳ [" .. typeTag .. "] " .. obj.Name
    b.TextColor3 = typeTag:find("GUI") and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(57, 255, 20)
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)
    
    entryCache[id] = b
    
    b.MouseButton1Click:Connect(function()
        Side.Visible = true
        OutputSayer.Text = "Status: Selected " .. obj.Name
        CommandBox.Text = tostring(obj:IsA("ValueBase") and obj.Value or obj.Name)
        InfoLabel.Text = "PATH: " .. id
        
        local connection
        connection = ExecuteBtn.MouseButton1Click:Connect(function()
            if obj:IsA("RemoteEvent") then obj:FireServer(CommandBox.Text)
            elseif obj:IsA("ValueBase") then pcall(function() obj.Value = CommandBox.Text end) end
            connection:Disconnect()
        end)
    end)
end


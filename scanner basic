                for _, key in pairs(moneyDepthKeywords) do if lowName:find(key) then isMoney = true break end end
                local tag = child:IsA("RemoteEvent") and "REMOTE" or child:IsA("RemoteFunction") and "REMOTE" or "BINDABLE"
                if isMoney and canAddToCategory("Money/Depth Remotes") then addEntry(child, "MONEY REMOTE", "Money/Depth Remotes") end

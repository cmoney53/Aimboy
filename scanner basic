local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Create ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "ScannerUI"
screenGui.Parent = playerGui

-- Main Frame
local main = Instance.new("Frame")
main.Size = UDim2.new(0, 400, 0, 300)
main.Position = UDim2.new(0.5, -200, 0.5, -150)
main.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
main.BorderSizePixel = 0
main.Parent = screenGui

-- Round corners
local corner = Instance.new("UICorner", main)
corner.CornerRadius = UDim.new(0, 12)

-- Title bar
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "GUI Scanner"
title.BackgroundTransparency = 1
title.TextColor3 = Color3.new(0,0,0)
title.Parent = main

-- Close button
local close = Instance.new("TextButton")
close.Size = UDim2.new(0, 30, 0, 30)
close.Position = UDim2.new(1, -30, 0, 0)
close.Text = "X"
close.Parent = main

close.MouseButton1Click:Connect(function()
	screenGui:Destroy()
end)

-- Minimize button
local minimize = Instance.new("TextButton")
minimize.Size = UDim2.new(0, 30, 0, 30)
minimize.Position = UDim2.new(1, -60, 0, 0)
minimize.Text = "-"
minimize.Parent = main

local minimized = false
minimize.MouseButton1Click:Connect(function()
	minimized = not minimized
	for _, v in pairs(main:GetChildren()) do
		if v ~= title and v ~= close and v ~= minimize then
			v.Visible = not minimized
		end
	end
end)

-- Dragging
local dragging, dragStart, startPos

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
	end
end)

title.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- List container
local listFrame = Instance.new("ScrollingFrame")
listFrame.Size = UDim2.new(0.5, 0, 1, -30)
listFrame.Position = UDim2.new(0, 0, 0, 30)
listFrame.CanvasSize = UDim2.new(0, 0, 2, 0)
listFrame.Parent = main

-- Side panel
local side = Instance.new("Frame")
side.Size = UDim2.new(0.5, 0, 1, -30)
side.Position = UDim2.new(0.5, 0, 0, 30)
side.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
side.Parent = main

local sideText = Instance.new("TextLabel")
sideText.Size = UDim2.new(1, 0, 1, 0)
sideText.Text = "Select something..."
sideText.BackgroundTransparency = 1
sideText.Parent = side

-- Scan GUIs
local function scanGUIs()
	for _, gui in pairs(playerGui:GetChildren()) do
		local button = Instance.new("TextButton")
		button.Size = UDim2.new(1, 0, 0, 30)
		button.Text = gui.Name
		button.Parent = listFrame

		button.MouseButton1Click:Connect(function()
			sideText.Text = "Selected: " .. gui.Name .. "\n\nOptions:\n- Open GUI\n- Simulated Outcome:\nGUI Visible"

			-- Example "execute"
			gui.Enabled = true
		end)
	end
end

scanGUIs()

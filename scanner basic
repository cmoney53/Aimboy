-- 6. CORE SCANNER LOGIC WITH CATEGORIES
local clickConn = nil
local collapsedCategories = {}

local function updateListVisibility()
    for _, item in pairs(Scroll:GetChildren()) do
        if item:IsA("TextButton") and not item.Name:find("Category") then
            local category = item:GetAttribute("ParentCategory")
            local isCollapsed = collapsedCategories[category]
            local matchesSearch = Search.Text == "" or item.Text:lower():find(Search.Text:lower())
            
            item.Visible = (not isCollapsed) and matchesSearch
        end
    end
end

local function addCategoryHeader(name, color)
    local h = Instance.new("TextButton")
    h.Size = UDim2.new(1, 0, 0, 35)
    h.BackgroundColor3 = color
    h.Text = collapsedCategories[name] and "  ▶ CATEGORY: " .. name:upper() or "  ▼ CATEGORY: " .. name:upper()
    h.TextColor3 = Color3.fromRGB(255, 255, 255)
    h.Font = Enum.Font.SourceSansBold
    h.TextSize = 16
    h.TextXAlignment = Enum.TextXAlignment.Left
    h.Name = "Category_" .. name
    h.Parent = Scroll
    Instance.new("UICorner", h)

    h.MouseButton1Click:Connect(function()
        collapsedCategories[name] = not collapsedCategories[name]
        h.Text = collapsedCategories[name] and "  ▶ CATEGORY: " .. name:upper() or "  ▼ CATEGORY: " .. name:upper()
        updateListVisibility()
    end)
end

local function addEntry(obj, typeTag, category)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  ↳ [" .. typeTag .. "] " .. obj.Name
    b:SetAttribute("ParentCategory", category)
    
    -- Visual Coding
    if typeTag:find("GUI") then b.TextColor3 = Color3.fromRGB(0, 200, 255)
    elseif typeTag:find("DATA") then b.TextColor3 = Color3.fromRGB(255, 180, 0)
    elseif typeTag:find("CMD") or typeTag:find("REMOTE") then b.TextColor3 = Color3.fromRGB(57, 255, 20)
    elseif typeTag:find("UTILITY") then b.TextColor3 = Color3.fromRGB(255, 80, 80)
    else b.TextColor3 = Color3.fromRGB(200, 200, 200) end
    
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    -- Initial visibility check
    b.Visible = not collapsedCategories[category]

    b.MouseButton1Click:Connect(function()
        Main.ClipsDescendants = false
        Side.Visible = true
        OutputSayer.Text = "Status: Selected " .. obj.Name
        CommandBox.Text = tostring(obj:IsA("ValueBase") and obj.Value or "1000")
        InfoLabel.Text = "NAME: " .. obj.Name .. "\nTYPE: " .. typeTag .. "\nTARGET: " .. TARGET_USER

        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
            local val = tonumber(CommandBox.Text) or CommandBox.Text
            
            pcall(function()
                if typeTag:find("GUI") then
                    obj.Enabled = true
                    for _, v in pairs(obj:GetDescendants()) do
                        if v:IsA("Frame") or v:IsA("ScrollingFrame") then v.Visible = true end
                    end
                    OutputSayer.Text = "Status: GUI Opened"
                elseif typeTag == "DATA" then
                    obj.Value = val
                    OutputSayer.Text = "Status: Applied Value"
                elseif obj:IsA("RemoteEvent") then
                    obj:FireServer(TARGET_USER, val)
                    obj:FireServer(val)
                    OutputSayer.Text = "Status: Event Fired"
                elseif obj:IsA("RemoteFunction") then
                    task.spawn(function() obj:InvokeServer(TARGET_USER, val) end)
                    OutputSayer.Text = "Status: Function Invoked"
                elseif obj:IsA("BindableEvent") then
                    obj:Fire(val)
                    OutputSayer.Text = "Status: Local Fire"
                end
            end)
        end)
    end)
end

-- 7. THE DEEP OMNI-SCAN ENGINE (CATEGORIZED)
local function runOmniScan()
    -- Clearing existing items safely
    for _, v in pairs(Scroll:GetChildren()) do 
        if not v:IsA("UIListLayout") then v:Destroy() end 
    end
    
    addCategoryHeader("Guis", Color3.fromRGB(0, 100, 150))
    for _, g in pairs(PlayerGui:GetChildren()) do
        if g:IsA("ScreenGui") and g ~= ScreenGui then
            addEntry(g, g.Enabled and "GUI" or "HIDDEN GUI", "Guis")
        end
    end
    
    addCategoryHeader("Data", Color3.fromRGB(150, 100, 0))
    local targetPlr = Players:FindFirstChild(TARGET_USER)
    if targetPlr then
        for _, v in pairs(targetPlr:GetDescendants()) do
            if v:IsA("ValueBase") then addEntry(v, "DATA", "Data") end
        end
    end

    addCategoryHeader("Remotes", Color3.fromRGB(0, 150, 50))
    addCategoryHeader("Utilities", Color3.fromRGB(150, 50, 50))

    local keywords = {"admin", "command", "server", "drop", "spawn", "give", "money", "cash", "rank"}
    local scanContainers = {ReplicatedStorage, workspace, game:GetService("Lighting"), game:GetService("StarterGui")}

    local function deepScan(parent)
        for _, child in pairs(parent:GetChildren()) do
            local lowName = child.Name:lower()
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                addEntry(child, "REMOTE", "Remotes")
            end
            for _, key in pairs(keywords) do
                if lowName:find(key) then
                    addEntry(child, "UTILITY", "Utilities")
                    break
                end
            end
            -- Avoid scanning player objects or huge terrain structures to prevent lag
            if not child:IsA("Player") and not child:IsA("Terrain") and not child:IsA("Folder") then
                pcall(function() 
                    if #child:GetChildren() > 0 then deepScan(child) end 
                end)
            end
        end
    end

    for _, container in pairs(scanContainers) do
        pcall(function() deepScan(container) end)
    end
    
    updateListVisibility()
end

-- 8. SEARCH & UPDATE LOOP
Search:GetPropertyChangedSignal("Text"):Connect(updateListVisibility)

-- One-time initial scan, then periodic light refreshes
task.spawn(function()
    while true do
        runOmniScan()
        task.wait(10) -- Longer wait to prevent UI stutter
    end
end)


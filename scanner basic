-- Core fire function — uses argMode to decide what to pass
local function doExecute(obj, typeTag)
    if not obj or not obj.Parent then
        OutputSayer.Text = "ERR: Object gone"
        logOutput("ERR: " .. tostring(obj and obj.Name or "?") .. " gone", Color3.fromRGB(255, 80, 80))
        return
    end

    -- Arg mode logic — VAL is identical to original working script
    local val = tonumber(CommandBox.Text) or CommandBox.Text

    if typeTag:find("GUI") then
        obj.Enabled = true
        for _, v in pairs(obj:GetDescendants()) do
            pcall(function()
                if v:IsA("Frame") or v:IsA("ScrollingFrame") or v:IsA("CanvasGroup") then v.Visible = true end
            end)
        end
        OutputSayer.Text = "Status: GUI Force-Opened"
        logOutput("GUI opened: " .. obj.Name)

    elseif typeTag == "DATA" then
        pcall(function() obj.Value = val end)
        OutputSayer.Text = "Status: Data Applied"
        logOutput("SET " .. obj.Name .. " = " .. tostring(val))

    elseif obj:IsA("RemoteEvent") then
        local ok, err = pcall(function()
            if argMode == "VAL" then obj:FireServer(val)
            elseif argMode == "PLAYER" then obj:FireServer(Player)
            elseif argMode == "NIL" then obj:FireServer(nil)
            elseif argMode == "NONE" then obj:FireServer()
            end
        end)
        if ok then
            OutputSayer.Text = "Fired [" .. argMode .. "] OK"
            logOutput("FIRE " .. obj:GetFullName() .. "\n  MODE=" .. argMode .. "  ARG=" .. tostring(val))
        else
            OutputSayer.Text = "ERR (see log)"
            logOutput("ERR FIRE " .. obj:GetFullName() .. "\n  " .. tostring(err), Color3.fromRGB(255, 80, 80))
        end

    elseif obj:IsA("RemoteFunction") then
        OutputSayer.Text = "Invoking [" .. argMode .. "]..."
        logOutput("INVOKE " .. obj:GetFullName() .. "\n  MODE=" .. argMode .. "  ARG=" .. tostring(val))
        task.spawn(function()
            local ok, result = pcall(function()
                if argMode == "VAL" then return obj:InvokeServer(val)
                elseif argMode == "PLAYER" then return obj:InvokeServer(Player)
                elseif argMode == "NIL" then return obj:InvokeServer(nil)
                elseif argMode == "NONE" then return obj:InvokeServer()
                end
            end)
            if ok then
                OutputSayer.Text = "Done"
                logOutput("RETURN " .. obj.Name .. "\n  => " .. tostring(result))
            else
                OutputSayer.Text = "ERR (see log)"
                logOutput("ERR INVOKE " .. obj.Name .. "\n  " .. tostring(result), Color3.fromRGB(255, 80, 80))
            end
        end)

    elseif obj:IsA("BindableEvent") then
        local ok, err = pcall(function()
            if argMode == "VAL" then obj:Fire(val)
            elseif argMode == "PLAYER" then obj:Fire(Player)
            elseif argMode == "NIL" then obj:Fire(nil)
            elseif argMode == "NONE" then obj:Fire()
            end
        end)
        if ok then
            OutputSayer.Text = "Bindable Fired [" .. argMode .. "]"
            logOutput("BIND:FIRE " .. obj:GetFullName() .. "\n  MODE=" .. argMode)
        else
            logOutput("ERR BIND:FIRE " .. obj.Name .. "\n  " .. tostring(err), Color3.fromRGB(255, 80, 80))
        end

    elseif obj:IsA("BindableFunction") then
        task.spawn(function()
            local ok, result = pcall(function()
                if argMode == "VAL" then return obj:Invoke(val)
                elseif argMode == "PLAYER" then return obj:Invoke(Player)
                elseif argMode == "NIL" then return obj:Invoke(nil)
                elseif argMode == "NONE" then return obj:Invoke()
                end
            end)
            if ok then
                logOutput("BIND:RETURN " .. obj.Name .. "\n  => " .. tostring(result))
            else
                logOutput("ERR BIND:INVOKE " .. obj.Name .. "\n  " .. tostring(result), Color3.fromRGB(255, 80, 80))
            end
        end)
    end
end


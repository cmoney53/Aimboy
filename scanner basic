--- SCANNING LOGIC ---

local selectedObj = nil

local function getSuggestions(type)
	for _, c in pairs(sideScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
	
	local list = {}
	if type == "Item" then
		for _, v in pairs(game:GetDescendants()) do 
			if v:IsA("Tool") then table.insert(list, v.Name) end 
		end
	elseif type == "Player" then
		for _, p in pairs(Players:GetPlayers()) do table.insert(list, p.Name) end
	end

	for _, name in pairs(list) do
		local b = Instance.new("TextButton", sideScroll)
		b.Size = UDim2.new(1, 0, 0, 20)
		b.Text = name
		b.BackgroundColor3 = Color3.fromRGB(20, 40, 20)
		b.TextColor3 = Color3.white
		b.MouseButton1Click:Connect(function() argInput.Text = name end)
	end
end

local function addToList(obj)
	local b = Instance.new("TextButton", scroll)
	b.Size = UDim2.new(1, 0, 0, 30)
	b.Text = " [" .. obj.ClassName .. "] " .. obj.Name
	b.BackgroundColor3 = Color3.fromRGB(20, 30, 20)
	b.TextColor3 = Color3.fromRGB(0, 255, 120)
	b.Font = Enum.Font.Code
	b.TextXAlignment = Enum.TextXAlignment.Left

	b.MouseButton1Click:Connect(function()
		selectedObj = obj
		side.Visible = true
		local low = obj.Name:lower()
		if string.find(low, "give") or string.find(low, "item") or string.find(low, "spawn") then
			getSuggestions("Item")
		elseif string.find(low, "kill") or string.find(low, "tp") then
			getSuggestions("Player")
		end
	end)
end

-- Refresh Scanner
for _, v in pairs(game:GetDescendants()) do
	pcall(function()
		if v:IsA("RemoteEvent") or (v:IsA("ScreenGui") and v.Parent ~= LP.PlayerGui) then
			addToList(v)
		end
	end)
end

-- Final Execution
exec.MouseButton1Click:Connect(function()
	if selectedObj and selectedObj:IsA("RemoteEvent") then
		selectedObj:FireServer(argInput.Text)
		print("Sent: " .. argInput.Text .. " to " .. selectedObj.Name)
	elseif selectedObj:IsA("ScreenGui") then
		selectedObj.Enabled = not selectedObj.Enabled
	end
end)

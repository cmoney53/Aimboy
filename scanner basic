local function ultraAutoFire(obj)
    -- Fires the remote with a comprehensive set of argument combos
    local autoCombos = {
        {{}, 0},
        {{Player}, 1},
        {{nil}, 1},
        {{1}, 1},
        {{true}, 1},
        {{false}, 1},
        {{"give"}, 1},
        {{"admin"}, 1},
        {{"exec"}, 1},
        {{"run"}, 1},
        {{Player, 1}, 2},
        {{Player, true}, 2},
        {{Player, "give"}, 2},
        {{Player, "admin"}, 2},
        {{Player, ""}, 2},
        {{1, Player}, 2},
        {{Player, 1, true}, 3},
        {{Player, "give", 1}, 3},
    }
    local okCount = 0
    task.spawn(function()
        for _, combo in ipairs(autoCombos) do
            local cargs, ccount = combo[1], combo[2]
            local ok, err = pcall(function()
                if obj:IsA("RemoteEvent") then
                    obj:FireServer(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("RemoteFunction") then
                    return obj:InvokeServer(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("BindableEvent") then
                    obj:Fire(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("BindableFunction") then
                    return obj:Invoke(table.unpack(cargs, 1, ccount))
                end
            end)
            if ok then okCount = okCount + 1 end
            task.wait(0.04)
        end
        logOutput("ULTRA AUTO: " .. obj.Name .. " — " .. okCount .. "/" .. #autoCombos .. " combos OK",
            Color3.fromRGB(255,60,255))
    end)
end


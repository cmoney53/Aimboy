-- 6. CORE SCANNER LOGIC WITH CATEGORIES
local clickConn = nil
local collapsedCategories = {}

local function addCategoryHeader(name, color)
    local existing = Scroll:FindFirstChild("Category_" .. name)
    if existing then
        return existing
    end

    local h = Instance.new("TextButton")
    h.Size = UDim2.new(1, 0, 0, 35)
    h.BackgroundColor3 = color
    h.Text = "  ▼ CATEGORY: " .. name:upper()
    h.TextColor3 = Color3.fromRGB(255, 255, 255)
    h.Font = Enum.Font.SourceSansBold
    h.TextSize = 16
    h.TextXAlignment = Enum.TextXAlignment.Left
    h.Name = "Category_" .. name
    h.Parent = Scroll
    Instance.new("UICorner", h)

    if collapsedCategories[name] then
        h.Text = "  ▶ CATEGORY: " .. name:upper()
    end

    h.MouseButton1Click:Connect(function()
        collapsedCategories[name] = not collapsedCategories[name]
        h.Text = collapsedCategories[name]
            and ("  ▶ CATEGORY: " .. name:upper())
            or  ("  ▼ CATEGORY: " .. name:upper())
    end)

    return h
end

local function addEntry(obj, typeTag, category)
    if collapsedCategories[category] then return end

    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  ↳ [" .. typeTag .. "] " .. obj.Name

    if typeTag:find("GUI") then
        b.TextColor3 = Color3.fromRGB(0, 200, 255)
    elseif typeTag:find("DATA") then
        b.TextColor3 = Color3.fromRGB(255, 180, 0)
    elseif typeTag:find("CMD") or typeTag:find("REMOTE") then
        b.TextColor3 = Color3.fromRGB(57, 255, 20)
    elseif typeTag:find("UTILITY") then
        b.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        b.TextColor3 = Color3.fromRGB(200, 200, 200)
    end

    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    if Search.Text ~= "" and not b.Text:lower():find(Search.Text:lower()) then
        b.Visible = false
    end

    b.MouseButton1Click:Connect(function()
        Main.ClipsDescendants = false
        Side.Visible = true
        OutputSayer.Text = "Status: Selected " .. obj.Name
        CommandBox.Text = tostring(obj:IsA("ValueBase") and obj.Value or obj.Name)
        InfoLabel.Text = "NAME: " .. obj.Name .. "\nTYPE: " .. typeTag .. "\nPATH: " .. obj:GetFullName()

        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
            local val = tonumber(CommandBox.Text) or CommandBox.Text

            if typeTag:find("GUI") and obj:IsA("ScreenGui") then
                obj.Enabled = true
                for _, v in pairs(obj:GetDescendants()) do
                    pcall(function()
                        if v:IsA("Frame") or v:IsA("ScrollingFrame") or v:IsA("CanvasGroup") then
                            v.Visible = true
                        end
                    end)
                end
                OutputSayer.Text = "Status: GUI Force-Opened"

            elseif typeTag == "DATA" and obj:IsA("ValueBase") then
                pcall(function() obj.Value = val end)
                OutputSayer.Text = "Status: Local Data Applied"

            elseif obj:IsA("RemoteEvent") then
                obj:FireServer(val)
                OutputSayer.Text = "Status: Remote Event Fired"

            elseif obj:IsA("RemoteFunction") then
                OutputSayer.Text = "Status: Invoking Function..."
                task.spawn(function() obj:InvokeServer(val) end)

            elseif obj:IsA("BindableEvent") then
                obj:Fire(val)
                OutputSayer.Text = "Status: Bindable Fired"
            end
        end)
    end)
end

-- 7. THE DEEP OMNI-SCAN ENGINE (CATEGORIZED)
local keywords = {"admin", "command", "server", "drop", "spawn", "give", "money", "cash", "rank"}

local function deepScan(parent, depth)
    depth = depth or 0
    if depth > MAX_DEPTH then return end

    for _, child in ipairs(parent:GetChildren()) do
        local lowName = child.Name:lower()

        -- Remotes
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            addEntry(child, "REMOTE", "Remotes")
        elseif child:IsA("BindableEvent") or child:IsA("BindableFunction") then
            addEntry(child, "BINDABLE", "Remotes")
        end

        -- Utilities / Commands
        for _, key in ipairs(keywords) do
            if lowName:find(key) then
                local tag = "UTILITY"
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    tag = "SERVER CMD"
                end
                addEntry(child, tag, "Utilities")
                break
            end
        end

        if not child:IsA("Player") and not child:IsA("Terrain") then
            deepScan(child, depth + 1)
        end
    end
end

local function runOmniScan()
    -- Clear only entries, keep category headers
    for _, v in pairs(Scroll:GetChildren()) do
        if v:IsA("TextButton") and not v.Name:find("Category_") then
            v:Destroy()
        end
    end

    -- CATEGORY: GUIS
    addCategoryHeader("Guis", Color3.fromRGB(0, 100, 150))
    for _, g in pairs(PlayerGui:GetChildren()) do
        if g:IsA("ScreenGui") and g ~= ScreenGui then
            addEntry(g, g.Enabled and "GUI" or "HIDDEN GUI", "Guis")
        end
    end

    -- CATEGORY: DATA & STATS
    addCategoryHeader("Data", Color3.fromRGB(150, 100, 0))
    for _, v in pairs(Player:GetDescendants()) do
        if v:IsA("ValueBase") then
            addEntry(v, "DATA", "Data")
        end
    end

    -- CATEGORY: REMOTES & UTILITIES
    addCategoryHeader("Remotes", Color3.fromRGB(0, 150, 50))
    addCategoryHeader("Utilities", Color3.fromRGB(150, 50, 50))

    -- Scan all services
    for _, service in ipairs(game:GetChildren()) do
        pcall(function()
            deepScan(service, 0)
        end)
    end
end

-- 8. SEARCH & UPDATE LOOP
Search:GetPropertyChangedSignal("Text"):Connect(function()

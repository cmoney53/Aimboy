-- Generate argument combos for rank-giving
local function rankBlastCombos(target, rankVal)
    local rv = tonumber(rankVal) or 255
    return {
        -- (player, rank)
        {target, rv},
        {target, tostring(rv)},
        {target.Name, rv},
        {target.Name, tostring(rv)},
        {target.UserId, rv},
        -- (rank, player)
        {rv, target},
        {rv, target.Name},
        -- Adonis-style: ":rank player 255"
        {":rank " .. target.Name .. " " .. tostring(rv)},
        {":promote " .. target.Name},
        {":admin " .. target.Name},
        {":setrank " .. target.Name .. " " .. tostring(rv)},
        -- HD Admin style
        {"rank", target, rv},
        {"promote", target, rv},
        {"admin", target},
        -- Table payload
        {{player=target, rank=rv}},
        {{name=target.Name, rank=rv}},
        {{userId=target.UserId, level=rv}},
        -- Lone player
        {target},
        {target.Name},
        -- (player, "admin")
        {target, "admin"},
        {target, "owner"},
        {target, "mod"},
        {target, "moderator"},
        -- (player, rank, bool)
        {target, rv, true},
        {target.Name, rv, true},
    }
end


        if b:IsA("TextButton") and not b.Name:find("Category_") then
            b.Visible = b.Text:lower():find(f) ~= nil
        end
    end
end)

task.spawn(function()
    while ScreenGui.Parent do
        runOmniScan()
        task.wait(REFRESH_DELAY)
    end
end)


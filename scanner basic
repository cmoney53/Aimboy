-- HARD HOOK — always on from script load, captures all FireServer/InvokeServer/Fire/Invoke
-- Uses rawget(self, "Name") to avoid re-entering __namecall
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "InvokeServer" or method == "Fire" or method == "Invoke" then
        local name = rawget(self, "Name") or "?"
        local args = {...}
        task.defer(function() addSnifferEntry(name, method, args) end)
    end
    return oldNamecall(self, ...)
end)


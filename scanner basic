-- Deep argument serializer — handles all Roblox types without calling IsA()
local function serializeArg(v, depth)
    depth = depth or 0
    local t = typeof(v)
    if t == "nil" then
        return "nil"
    elseif t == "boolean" or t == "number" then
        return tostring(v)
    elseif t == "string" then
        return '"' .. v:sub(1, 60) .. (v:len() > 60 and '..."' or '"')
    elseif t == "table" then
        if depth >= 2 then return "{...}" end
        local parts = {}
        local count = 0
        for k, val in pairs(v) do
            count = count + 1
            if count > 8 then table.insert(parts, "...") break end
            local ks = type(k) == "string" and k or ("[" .. tostring(k) .. "]")
            table.insert(parts, ks .. "=" .. serializeArg(val, depth + 1))
        end
        return "{" .. table.concat(parts, ", ") .. "}"
    elseif t == "Vector3" then
        return string.format("V3(%.2f,%.2f,%.2f)", v.X, v.Y, v.Z)
    elseif t == "Vector2" then
        return string.format("V2(%.2f,%.2f)", v.X, v.Y)
    elseif t == "CFrame" then
        local p = v.Position
        return string.format("CF(%.1f,%.1f,%.1f)", p.X, p.Y, p.Z)
    elseif t == "Color3" then
        return string.format("C3(%.0f,%.0f,%.0f)", v.R*255, v.G*255, v.B*255)
    elseif t == "UDim2" then
        return string.format("UD2(%.2f,%d,%.2f,%d)", v.X.Scale, v.X.Offset, v.Y.Scale, v.Y.Offset)
    elseif t == "UDim" then
        return string.format("UD(%.2f,%d)", v.Scale, v.Offset)
    elseif t == "EnumItem" then
        return "Enum." .. tostring(v)
    elseif t == "Instance" then
        local ok, path = pcall(function() return v:GetFullName() end)
        return ok and ("[" .. path .. "]") or "[Instance]"
    else
        local s = tostring(v)
        return s:sub(1, 50)
    end
end

local function serializeArgs(args)
    if #args == 0 then return "<none>" end
    local parts = {}
    for _, v in ipairs(args) do
        table.insert(parts, serializeArg(v))
    end
    return table.concat(parts, ", ")
end

local function addSnifferEntry(remoteName, method, args)
    local timestamp = string.format("%.1f", tick() % 1000)
    local argStr = serializeArgs(args)

    local row = Instance.new("TextLabel")
    row.Size = UDim2.new(1, -8, 0, 22)
    row.BackgroundColor3 = Color3.fromRGB(12, 5, 18)
    row.Font = Enum.Font.Code
    row.TextSize = 11
    row.TextColor3 = Color3.fromRGB(255, 80, 200)
    row.TextXAlignment = Enum.TextXAlignment.Left
    row.TextTruncate = Enum.TextTruncate.AtEnd
    row.Text = string.format("  [%s] %s::%s  %s", timestamp, remoteName, method, argStr)
    row.Parent = SnifferScroll
    Instance.new("UICorner", row)

    table.insert(snifferLog, row)
    if #snifferLog > MAX_LOG then
        local oldest = table.remove(snifferLog, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
    end
end

-- HARD HOOK — always active from script load, no toggle gate.
-- Captures ALL FireServer / InvokeServer / Fire / Invoke calls game-wide.
-- Uses rawget for Name to avoid re-entering __namecall.
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer"
    or method == "InvokeServer"
    or method == "Fire"
    or method == "Invoke"
    then
        local name = rawget(self, "Name") or "Unknown"
        local args = {...}
        task.defer(function() addSnifferEntry(name, method, args) end)
    end
    return oldNamecall(self, ...)
end)


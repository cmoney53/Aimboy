-- Populate ultra scroll from a registry
local function showUltraTab(tabName)
    ultraActiveTab = tabName
    -- Highlight active tab
    for tname, tb in pairs(ultraTabBtns) do
        tb.BackgroundColor3 = Color3.fromRGB(20,20,20)
    end
    local tc = ultraTabColors[tabName]
    ultraTabBtns[tabName].BackgroundColor3 = Color3.fromRGB(
        math.floor(tc.R*255*0.3), math.floor(tc.G*255*0.3), math.floor(tc.B*255*0.3))

    clearUltraList()
    local registry
    if tabName == "EXEC"  then registry = ultraExecRegistry
    elseif tabName == "ADMIN" then registry = ultraAdminRegistry
    elseif tabName == "MONEY" then registry = ultraMoneyRegistry
    else registry = ultraAllRegistry end

    if #registry == 0 then
        local lbl = makeLabel(UltraScroll, "No entries — run ULTRA SCAN first", 6, 6, 400, 20, Color3.fromRGB(150,150,150), 11)
        table.insert(ultraEntries, lbl)
        return
    end

    -- Sort by total score descending
    local sorted = {}
    for _, e in ipairs(registry) do table.insert(sorted, e) end
    table.sort(sorted, function(a,b) return (a.es+a.as+a.ms) > (b.es+b.bs+b.ms) end)

    for _, e in ipairs(sorted) do
        if e.obj and e.obj.Parent then
            addUltraEntry(e.obj, e.tag, e.es, e.as, e.ms)
        end
    end
    ultraProgressLabel.Text = "Tab: " .. tabName .. " — " .. #sorted .. " entries"
end


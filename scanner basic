local rankSpoofIdx = nil

local function applyRankSpoof()
    -- Hook the three core group methods
    pcall(function() hookfunction(Player.GetRankInGroup, function() return 255 end) end)
    pcall(function() hookfunction(Player.GetRoleInGroup, function() return "Owner" end) end)
    pcall(function() hookfunction(Player.IsInGroup,      function() return true  end) end)
    -- Deep __index hook: intercept any property lookup that sounds rank-related
    pcall(function()
        if rankSpoofIdx then return end  -- don't double-hook
        rankSpoofIdx = hookmetamethod(game, "__index", function(self, key)
            local lk = tostring(key):lower()
            if self == Player then
                if lk == "userid"      then return rankSpoofIdx(self, key) end  -- pass through real UID
                if lk == "name"        then return rankSpoofIdx(self, key) end  -- pass real name unless name-spoofed
            end
            -- Intercept rank/role property reads on any object
            if lk == "rankvalue" or lk == "rank" or lk == "adminrank" then return 255 end
            if lk == "rolevalue" or lk == "role" or lk == "adminrole"  then return "Owner" end
            if lk == "isadmin"   or lk == "admin"                      then return true   end
            return rankSpoofIdx(self, key)
        end)
    end)
end


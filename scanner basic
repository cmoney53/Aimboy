-- 6. DYNAMIC OUTCOME ENGINE
local function generateOutcome(obj)
    local n = obj.Name:lower()
    if obj:IsA("ScreenGui") then 
        return "Type: GUI Frame\nAction: Local Toggle Detected.\nOutcome: Opening this interface might reveal hidden dev menus or admin buttons." 
    end
    if n:find("admin") or n:find("mod") then 
        return "Type: Admin Remote\nAction: Privileged Command.\nOutcome: [REJECTED] Server-side validation requires higher permissions." 
    end
    if n:find("spawn") then 
        return "Type: Action Remote\nAction: Character/Object Creation.\nOutcome: Enter /spawn [Name]. Status: Waiting for player input." 
    end
    if n:find("kill") or n:find("ban") then 
        return "Type: Security Remote\nAction: Destructive Command.\nOutcome: [DENIED] Unauthorized execution attempt logged." 
    end
    return "Type: General System Bridge\nAction: Execution.\nOutcome: Possible outcome: " .. obj.Name .. " triggers server-side logic."
end


local function addEntry(name, typeTag, category, extraData, fullPath, actualObj)
    if collapsedCategories[category] then return end
    
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  ↳ [" .. typeTag .. "] " .. name
    b.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    if category == "Sniffer" then b.TextColor3 = Color3.fromRGB(255, 0, 255)
    elseif typeTag:find("GUI") then b.TextColor3 = Color3.fromRGB(0, 200, 255)
    elseif typeTag:find("REMOTE") then b.TextColor3 = Color3.fromRGB(57, 255, 20) end
    
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        Side.Visible = true
        selectedObject = actualObj
        OutputSayer.Text = "Viewing: " .. name
        CommandBox.Text = extraData or "No extra data"
        InfoLabel.Text = "SOURCE: " .. category .. "\nTYPE: " .. typeTag .. "\nPATH: " .. (fullPath or "N/A") .. "\nTIMESTAMP: " .. (os.date("%X"))
    end)
end

-- 8. SCAN & REFRESH LOGIC (From V21)
local isHeavyScanning = false
local function runOmniScan()
    if isHeavyScanning then return end
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    
    -- --- SNIFFER LOGS ---
    addCategoryHeader("Sniffer", Color3.fromRGB(100, 0, 100))
    for _, log in pairs(sniffedLogs) do
        addEntry(log.Name, log.Type, "Sniffer", log.Args, log.Path)
    end

    -- --- GUIS ---
    addCategoryHeader("Guis", Color3.fromRGB(0, 100, 150))
    for _, g in pairs(PlayerGui:GetChildren()) do
        if g:IsA("ScreenGui") and g ~= ScreenGui then
            addEntry(g.Name, "GUI", "Guis", "Enabled: " .. tostring(g.Enabled), g:GetFullName(), g)
        end
    end
end

-- 9. HEAVY SCAN ENGINE (Recursive Search)
local function performHeavySearch()
    isHeavyScanning = true
    runOmniScan() -- Clear and do basics first
    
    local scanTargets = {ReplicatedStorage, Lighting, StarterGui, workspace, game:GetService("JointsService")}
    local keywords = {"Admin", "Cash", "Money", "Remote", "Give", "Mod", "Rank", "Ban", "Set", "Data", "Cmd", "Server", "Event", "Function"}
    
    for _, container in pairs(scanTargets) do
        addCategoryHeader(container.Name, Color3.fromRGB(40, 40, 40))
        local descendants = container:GetDescendants()
        for _, item in pairs(descendants) do
            local isSpecial = false
            local lowName = item.Name:lower()
            
            if item:IsA("RemoteEvent") or item:IsA("RemoteFunction") or item:IsA("BindableEvent") then
                isSpecial = true
            end
            for _, key in pairs(keywords) do
                if lowName:find(key:lower()) then isSpecial = true break end
            end
            
            if isSpecial then
                addEntry(item.Name, item.ClassName:upper(), container.Name, "Found via Deep Scan", item:GetFullName(), item)
            end
        end
    end
    isHeavyScanning = false
end


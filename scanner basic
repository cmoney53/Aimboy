        if g:IsA("ScreenGui") and g ~= ScreenGui then
            addEntry(g, g.Enabled and "GUI" or "HIDDEN GUI")
        end
    end
    
    -- Scan Values (Stats/Money)
    for _, v in pairs(Player:GetDescendants()) do
        if v:IsA("ValueBase") then addEntry(v, "DATA") end
    end

    -- Deep Remote Scan
    local function scan(parent)
        for _, child in pairs(parent:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                addEntry(child, "CMD")
            elseif not child:IsA("Player") then
                pcall(function() scan(child) end)
            end
        end
    end

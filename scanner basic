addCategoryHeader("Utilities", Color3.fromRGB(150, 50, 50))
addCategoryHeader("Scripts", Color3.fromRGB(80, 0, 150))

local seenRemotes = {}
local scanStepCount = 0

local function deepScan(parent)
    for _, child in pairs(parent:GetChildren()) do
        local lowName = child.Name:lower()
        local id = ""
        pcall(function() id = child:GetFullName() end)
        if id == "" then id = tostring(child) end

        -- Yield every 25 objects so the game doesn't freeze
        scanStepCount = scanStepCount + 1
        if scanStepCount % 25 == 0 then task.wait() end

        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
            if not seenRemotes[id] then
                seenRemotes[id] = true
                local isAdmin = false
                local isMoney = false
                for _, key in pairs(adminKeywords) do
                    if lowName:find(key) then isAdmin = true break end
                end
                for _, key in pairs(moneyDepthKeywords) do
                    if lowName:find(key) then isMoney = true break end
                end
                if isMoney and canAddToCategory("Money/Depth Remotes") then
                    addEntry(child, "MONEY REMOTE", "Money/Depth Remotes")
                end
                if isAdmin and canAddToCategory("Admin Remotes") then
                    addEntry(child, "ADMIN REMOTE", "Admin Remotes")
                end
                if canAddToCategory("Remotes") then
                    addEntry(child, "REMOTE", "Remotes")
                end
            end
        elseif child:IsA("BindableEvent") or child:IsA("BindableFunction") then
            if not seenRemotes[id] then
                seenRemotes[id] = true
                if canAddToCategory("Remotes") then
                    addEntry(child, "BINDABLE", "Remotes")
                end
            end
        end

        -- Keyword utilities (non-remote objects matching keywords)
        if not child:IsA("RemoteEvent") and not child:IsA("RemoteFunction") then
            for _, key in pairs(adminKeywords) do
                if lowName:find(key) then
                    if child:IsA("ValueBase") then
                        if canAddToCategory("Admin Remotes") then addEntry(child, "ADMIN DATA", "Admin Remotes") end
                    elseif child:IsA("LocalScript") or child:IsA("Script") or child:IsA("ModuleScript") then
                        if canAddToCategory("Scripts") then addEntry(child, "SCRIPT[" .. child.ClassName .. "]", "Scripts") end
                    else
                        if canAddToCategory("Utilities") then addEntry(child, "UTILITY", "Utilities") end
                    end
                    break
                end
            end
        end

        -- All local/module scripts (for intel) — only if category is open
        if child:IsA("LocalScript") or child:IsA("ModuleScript") then
            if not collapsedCategories["Scripts"] and canAddToCategory("Scripts") then
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, 0, 0, 32)
                b.BackgroundColor3 = Color3.fromRGB(20, 10, 30)
                b.Text = "  ↳ [" .. child.ClassName .. "] " .. child.Name
                b.TextColor3 = Color3.fromRGB(180, 100, 255)
                b.TextXAlignment = Enum.TextXAlignment.Left
                b.Parent = Scroll
                Instance.new("UICorner", b)
                -- Store search metadata for this script button
                local scriptPath = ""
                pcall(function() scriptPath = child:GetFullName():lower() end)
                entryMeta[b] = {
                    name    = child.Name:lower(),
                    typeTag = child.ClassName:lower(),
                    path    = scriptPath,
                    category = "Scripts",
                }
                categoryEntries["Scripts"] = categoryEntries["Scripts"] or {}
                table.insert(categoryEntries["Scripts"], b)

                b.MouseButton1Click:Connect(function()
                    stopSpam()
                    selectedObj = child
                    selectedTypeTag = child.ClassName:upper()
                    OutputSayer.Text = "Selected: " .. child.Name
                    CommandBox.Text = child.Name
                    InfoLabel.Text = "NAME: " .. child.Name .. "\nTYPE: " .. child.ClassName .. "\nPATH: " .. child:GetFullName() .. "\n[EXECUTE = require | type fn name to call it]"
                    Main.ClipsDescendants = false
                    Side.Visible = true
                    if clickConn then clickConn:Disconnect() end
                    clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
                        doExecute(selectedObj, selectedTypeTag)
                    end)
                end)
            end
        end

        if not child:IsA("Player") and not child:IsA("Terrain") then
            pcall(function() deepScan(child) end)
        end
    end
end


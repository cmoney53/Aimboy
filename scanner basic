-- DATA
local currentObjects = {}

-- REMOTE SCAN
local function GetRemotes()
    local t = {}
    for _,v in ipairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            table.insert(t,v)
        end
    end
    return t
end

-- GUI SCAN
local function GetGuis()
    local t = {}

    local function scan(p)
        for _,v in ipairs(p:GetDescendants()) do
            if v:IsA("ScreenGui") or v:IsA("Frame") then
                table.insert(t,v)
            end
        end
    end

    if player:FindFirstChild("PlayerGui") then
        scan(player.PlayerGui)
    end

    pcall(function()
        scan(game:GetService("CoreGui"))
    end)

    return t
end

-- PREDICTION
local function Predict(name)
    name = name:lower()

    if name:find("spawn") then
        return "Spawns something. Try: player name"
    elseif name:find("give") then
        return "Gives item"
    elseif name:find("tp") then
        return "Teleports player"
    elseif name:find("kill") then
        return "Kills player"
    else
        return "Unknown behavior"
    end
end

-- OPEN GUI
local function OpenGui(gui)
    if gui:IsA("ScreenGui") then
        gui.Enabled = true
    end

    for _,v in ipairs(gui:GetDescendants()) do
        if v:IsA("GuiObject") then
            v.Visible = true
        end
    end
end

-- REFRESH LIST
local function Refresh()
    list:ClearAllChildren()
    layout.Parent = list

    local query = search.Text:lower()

    for _,obj in ipairs(currentObjects) do
        if obj.Name:lower():find(query) then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,0,0,25)
            btn.Text = obj.Name
            btn.Parent = list

            btn.MouseButton1Click:Connect(function()

                if mode == "remotes" then
                    info.Text =
                        "Remote: "..obj.Name..
                        "\nType: "..obj.ClassName..
                        "\n\nPrediction:\n"..Predict(obj.Name)

                    execute.MouseButton1Click:Connect(function()
                        local args = {}

                        for word in input.Text:gmatch("%S+") do
                            table.insert(args,word)
                        end

                        pcall(function()
                            if obj:IsA("RemoteEvent") then
                                obj:FireServer(unpack(args))
                            else
                                obj:InvokeServer(unpack(args))
                            end
                        end)
                    end)

                else
                    info.Text =
                        "GUI: "..obj.Name..
                        "\nType: "..obj.ClassName

                    execute.MouseButton1Click:Connect(function()
                        OpenGui(obj)
                    end)
                end

            end)
        end
    end
end

-- TAB SWITCH
tabRemotes.MouseButton1Click:Connect(function()
    mode = "remotes"
    currentObjects = GetRemotes()
    Refresh()
end)

tabGuis.MouseButton1Click:Connect(function()
    mode = "guis"
    currentObjects = GetGuis()
    Refresh()
end)

-- SEARCH
search:GetPropertyChangedSignal("Text"):Connect(Refresh)

-- INIT
currentObjects = GetRemotes()
Refresh()

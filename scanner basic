--- SCANNING ENGINE ---

local selectedTarget = nil

local function updateSideList(category)
	for _, c in pairs(sideScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
	
	local items = {}
	-- Scans only client-accessible areas to prevent "Empty GUI" crashes
	local locations = {game:GetService("ReplicatedStorage"), game:GetService("Lighting"), game.Workspace}
	
	for _, loc in pairs(locations) do
		for _, obj in pairs(loc:GetDescendants()) do
			pcall(function()
				if category == "Items" and obj:IsA("Tool") then
					table.insert(items, obj.Name)
				elseif category == "Players" and obj:IsA("Player") then
					table.insert(items, obj.Name)
				end
			end)
		end
	end
	
	for _, name in pairs(items) do
		local b = Instance.new("TextButton", sideScroll)
		b.Size = UDim2.new(1, 0, 0, 25)
		b.Text = name
		b.BackgroundColor3 = Color3.fromRGB(20, 40, 20)
		b.TextColor3 = Color3.white
		b.MouseButton1Click:Connect(function() argInput.Text = name end)
	end
end

local function addEntry(obj)
	local b = Instance.new("TextButton", scroll)
	b.Size = UDim2.new(1, 0, 0, 30)
	b.Text = " [" .. obj.ClassName .. "] " .. obj.Name
	b.BackgroundColor3 = Color3.fromRGB(20, 35, 20)
	b.TextColor3 = Color3.fromRGB(0, 255, 120)
	b.Font = Enum.Font.Code
	b.TextXAlignment = Enum.TextXAlignment.Left

	b.MouseButton1Click:Connect(function()
		selectedTarget = obj
		side.Visible = true
		local n = obj.Name:lower()
		if string.find(n, "give") or string.find(n, "spawn") or string.find(n, "item") then
			updateSideList("Items")
		else
			updateSideList("Players")
		end
	end)
end

-- Systematic Service Scan
local services = {"ReplicatedStorage", "Lighting", "Workspace", "StarterGui"}

for _, sName in pairs(services) do
	local service = game:GetService(sName)
	for _, v in pairs(service:GetDescendants()) do
		pcall(function()
			if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") or (v:IsA("ScreenGui") and v.Parent ~= LP.PlayerGui) then
				addEntry(v)
			end
		end)
	end
	task.wait(0.1) -- Small delay to prevent lag
end

exec.MouseButton1Click:Connect(function()
	if not selectedTarget then return end
	if selectedTarget:IsA("RemoteEvent") then
		selectedTarget:FireServer(argInput.Text)
	elseif selectedTarget:IsA("RemoteFunction") then
		selectedTarget:InvokeServer(argInput.Text)
	elseif selectedTarget:IsA("ScreenGui") then
		selectedTarget.Enabled = not selectedTarget.Enabled
	end
end)

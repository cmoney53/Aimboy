--- FUNCTIONALITY ---

local selectedTarget = nil

-- Minecraft-style Dynamic Suggester
local function getSuggestions(category)
    for _, child in pairs(sideScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local found = {}
    if category == "Items" then
        for _, v in pairs(game:GetDescendants()) do
            pcall(function()
                if v:IsA("Tool") or v:IsA("HopperBin") then table.insert(found, v.Name) end
            end)
        end
    elseif category == "Players" then
        for _, p in pairs(Players:GetPlayers()) do table.insert(found, p.Name) end
    end
    
    for _, name in pairs(found) do
        local b = Instance.new("TextButton", sideScroll)
        b.Size = UDim2.new(1, 0, 0, 25)
        b.Text = name
        b.BackgroundColor3 = Color3.fromRGB(20, 40, 20)
        b.TextColor3 = Color3.white
        b.Font = Enum.Font.Code
        b.MouseButton1Click:Connect(function() argInput.Text = name end)
    end
end

-- Scanner Logic
local function runScan()
    scroll:ClearAllChildren()
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)
    
    local allObjs = game:GetDescendants()
    for i, v in ipairs(allObjs) do
        pcall(function()
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") or (v:IsA("ScreenGui") and v.Parent ~= LP.PlayerGui) then
                local item = Instance.new("TextButton", scroll)
                item.Size = UDim2.new(1, 0, 0, 35)
                item.Text = " [" .. v.ClassName .. "] " .. v.Name
                item.BackgroundColor3 = Color3.fromRGB(15, 30, 15)
                item.TextColor3 = Color3.fromRGB(0, 255, 100)
                item.Font = Enum.Font.Code
                item.TextXAlignment = Enum.TextXAlignment.Left

                item.MouseButton1Click:Connect(function()
                    selectedTarget = v
                    side.Visible = true
                    local n = v.Name:lower()
                    if string.find(n, "give") or string.find(n, "spawn") or string.find(n, "item") then
                        getSuggestions("Items")
                    else
                        getSuggestions("Players")
                    end
                end)
            end
        end)
        if i % 150 == 0 then task.wait() end -- Prevent Frame Drops
    end
end

-- Execution logic
execBtn.MouseButton1Click:Connect(function()
    if not selectedTarget then return end
    
    if selectedTarget:IsA("RemoteEvent") then
        selectedTarget:FireServer(argInput.Text)
    elseif selectedTarget:IsA("RemoteFunction") then
        selectedTarget:InvokeServer(argInput.Text)
    elseif selectedTarget:IsA("ScreenGui") then
        selectedTarget.Enabled = not selectedTarget.Enabled
    end
end)

-- Initial Startup
task.spawn(runScan)

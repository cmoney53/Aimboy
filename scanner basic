-- Helper: score a name for how likely it is to be a given type (0 = no match)
local function scoreKeywords(name, keywords)
    local low = name:lower()
    local score = 0
    for _, kw in ipairs(keywords) do
        if low:find(kw, 1, true) then
            score = score + (kw:len() > 5 and 2 or 1)
        end
    end
    return score
end


local function addEntry(obj, typeTag, category)
    if collapsedCategories[category] then return end

    -- Register fireable remotes
    if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") or obj:IsA("BindableEvent") or obj:IsA("BindableFunction") then
        table.insert(remoteRegistry, {obj = obj, typeTag = typeTag})
    end

    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  ↳ [" .. typeTag .. "] " .. obj.Name
    if typeTag:find("GUI") then b.TextColor3 = Color3.fromRGB(0, 200, 255)
    elseif typeTag:find("DATA") then b.TextColor3 = Color3.fromRGB(255, 180, 0)
    elseif typeTag:find("ADMIN") then b.TextColor3 = Color3.fromRGB(255, 60, 60)
    elseif typeTag:find("CMD") or typeTag:find("REMOTE") then b.TextColor3 = Color3.fromRGB(57, 255, 20)
    elseif typeTag:find("SCRIPT") then b.TextColor3 = Color3.fromRGB(180, 100, 255)
    elseif typeTag:find("UTILITY") then b.TextColor3 = Color3.fromRGB(255, 80, 80)
    else b.TextColor3 = Color3.fromRGB(200, 200, 200) end
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    if Search.Text ~= "" and not b.Text:lower():find(Search.Text:lower()) then b.Visible = false end

    b.MouseButton1Click:Connect(function()
        stopSpam()
        selectedObj = obj
        selectedTypeTag = typeTag
        Main.ClipsDescendants = false
        Side.Visible = true
        OutputSayer.Text = "Status: Selected " .. obj.Name
        -- Original CommandBox fill logic — untouched
        CommandBox.Text = tostring(obj:IsA("ValueBase") and obj.Value or obj.Name)
        InfoLabel.Text = "NAME: " .. obj.Name .. "\nTYPE: " .. typeTag .. "\nPATH: " .. obj:GetFullName()

        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
            doExecute(selectedObj, selectedTypeTag)
        end)
    end)
end

-- 7. EXTENDED OMNI-SCAN ENGINE
local adminKeywords = {
    "admin","command","server","drop","spawn","give","money","cash","rank",
    "ban","kick","god","fly","speed","noclip","teleport","invisible","freeze",
    "kill","damage","heal","respawn","item","weapon","tool","pet","data","save",
    "load","reset","unlock","upgrade","purchase","buy","sell","trade","transfer",
    "claim","redeem","code","promo","quest","mission","level","exp","xp","vip","owner"
}

local allServices = {
    "ReplicatedStorage","Workspace","Lighting","StarterGui","StarterPack",
    "StarterPlayer","Teams","SoundService","TextChatService","TweenService",
    "ReplicatedFirst","Players","Chat","InsertService","MarketplaceService"
}

local function runOmniScan()
    for _, v in pairs(Scroll:GetChildren()) do if not v:IsA("UIListLayout") then v:Destroy() end end
    remoteRegistry = {}

    -- GUIs (enabled + hidden)
    addCategoryHeader("Guis", Color3.fromRGB(0, 100, 150))
    for _, g in pairs(PlayerGui:GetChildren()) do
        if g:IsA("ScreenGui") and g ~= ScreenGui then
            addEntry(g, g.Enabled and "GUI" or "HIDDEN GUI", "Guis")
        end
    end

    -- Player Data/Values
    addCategoryHeader("Data", Color3.fromRGB(150, 100, 0))
    for _, v in pairs(Player:GetDescendants()) do
        if v:IsA("ValueBase") then addEntry(v, "DATA", "Data") end
    end

    -- Admin-specific remotes (top priority)
    addCategoryHeader("Admin Remotes", Color3.fromRGB(180, 0, 0))
    -- Standard remotes/bindables
    addCategoryHeader("Remotes", Color3.fromRGB(0, 150, 50))
    -- Keyword-matched utilities
    addCategoryHeader("Utilities", Color3.fromRGB(150, 50, 50))
    -- LocalScripts (intelligence — shows admin script names)
    addCategoryHeader("Scripts", Color3.fromRGB(80, 0, 150))

    local seenRemotes = {}

    local function deepScan(parent)
        for _, child in pairs(parent:GetChildren()) do
            local lowName = child.Name:lower()
            local id = tostring(child)

            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                if not seenRemotes[id] then
                    seenRemotes[id] = true
                    local isAdmin = false
                    for _, key in pairs(adminKeywords) do
                        if lowName:find(key) then isAdmin = true break end
                    end
                    if isAdmin then
                        addEntry(child, "ADMIN REMOTE", "Admin Remotes")
                    end
                    addEntry(child, "REMOTE", "Remotes")
                end
            elseif child:IsA("BindableEvent") or child:IsA("BindableFunction") then
                if not seenRemotes[id] then
                    seenRemotes[id] = true
                    addEntry(child, "BINDABLE", "Remotes")
                end
            end

            -- Keyword utilities (non-remote objects matching keywords)
            if not child:IsA("RemoteEvent") and not child:IsA("RemoteFunction") then
                for _, key in pairs(adminKeywords) do
                    if lowName:find(key) then
                        if child:IsA("ValueBase") then
                            addEntry(child, "ADMIN DATA", "Admin Remotes")

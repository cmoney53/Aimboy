local function addSnifferEntry(remoteName, method, args)
    local timestamp = string.format("%.1f", tick() % 1000)
    local argStr = ""
    for i, v in ipairs(args) do
        local s = tostring(v)
        if #s > 40 then s = s:sub(1, 40) .. "..." end
        argStr = argStr .. (i > 1 and ", " or "") .. s
    end
    if argStr == "" then argStr = "<none>" end

    local row = Instance.new("TextLabel")
    row.Size = UDim2.new(1, -8, 0, 22)
    row.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    row.Font = Enum.Font.Code
    row.TextSize = 11
    row.TextColor3 = Color3.fromRGB(255, 80, 200)
    row.TextXAlignment = Enum.TextXAlignment.Left
    row.TextTruncate = Enum.TextTruncate.AtEnd
    row.Text = string.format("  [%s] %s :: %s  =>  %s", timestamp, method, remoteName, argStr)
    row.Parent = SnifferScroll
    Instance.new("UICorner", row)

    table.insert(snifferLog, row)
    if #snifferLog > MAX_LOG then
        local oldest = table.remove(snifferLog, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
    end
end

-- Hook via __namecall metamethod
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if snifferActive then
        if method == "FireServer" and self:IsA("RemoteEvent") then
            local args = {...}
            task.defer(function() addSnifferEntry(self.Name, "FireServer", args) end)
        elseif method == "InvokeServer" and self:IsA("RemoteFunction") then
            local args = {...}
            task.defer(function() addSnifferEntry(self.Name, "InvokeServer", args) end)
        elseif method == "Fire" and self:IsA("BindableEvent") then
            local args = {...}
            task.defer(function() addSnifferEntry(self.Name, "Fire (Bindable)", args) end)
        end
    end
    return oldNamecall(self, ...)
end)


local function ultraAutoFire(obj)
    -- Fires the remote with a comprehensive set of argument combos (stat-gain focused)
    local autoCombos = {
        -- No-arg
        {{}, 0},
        -- Single player
        {{Player}, 1},
        -- Single values
        {{nil}, 1}, {{1}, 1}, {{10}, 1}, {{100}, 1},
        {{true}, 1}, {{false}, 1},
        -- Stat/action strings
        {{"give"}, 1}, {{"gain"}, 1}, {{"add"}, 1}, {{"increment"}, 1},
        {{"strength"}, 1}, {{"wins"}, 1}, {{"speed"}, 1},
        {{"walk"}, 1}, {{"step"}, 1}, {{"collect"}, 1},
        {{"admin"}, 1}, {{"exec"}, 1}, {{"run"}, 1},
        -- Player + number
        {{Player, 1}, 2}, {{Player, 10}, 2}, {{Player, 100}, 2},
        {{Player, true}, 2}, {{Player, false}, 2}, {{1, Player}, 2},
        -- Player + stat name
        {{Player, "strength"}, 2}, {{Player, "wins"}, 2},
        {{Player, "speed"}, 2}, {{Player, "walk"}, 2},
        {{Player, "gain"}, 2}, {{Player, "give"}, 2},
        {{Player, "admin"}, 2}, {{Player, ""}, 2},
        -- Stat name + player
        {{"strength", Player}, 2}, {{"wins", Player}, 2},
        -- Player + stat + amount
        {{Player, "strength", 1}, 3}, {{Player, "wins", 1}, 3},
        {{Player, "speed", 1}, 3}, {{Player, 1, "strength"}, 3},
        {{Player, 1, "wins"}, 3}, {{Player, 1, true}, 3},
        {{Player, "give", 1}, 3}, {{Player, "admin", true}, 3},
        -- Table payloads
        {{{stat="strength", amount=1}}, 1},
        {{{stat="wins", amount=1}}, 1},
        {{{player=Player, amount=1}}, 1},
        -- UserId
        {{Player.UserId}, 1}, {{Player.UserId, 1}, 2},
    }
    local okCount = 0
    task.spawn(function()
        for _, combo in ipairs(autoCombos) do
            local cargs, ccount = combo[1], combo[2]
            local ok, err = pcall(function()
                if obj:IsA("RemoteEvent") then
                    obj:FireServer(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("RemoteFunction") then
                    return obj:InvokeServer(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("BindableEvent") then
                    obj:Fire(table.unpack(cargs, 1, ccount))
                elseif obj:IsA("BindableFunction") then
                    return obj:Invoke(table.unpack(cargs, 1, ccount))

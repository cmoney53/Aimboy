                logOutput("ERR BIND:INVOKE " .. obj.Name .. "\n  " .. tostring(result), Color3.fromRGB(255, 80, 80))
            end
        end
    end)

elseif obj:IsA("ModuleScript") then
    local funcName = (CommandBox.Text ~= "" and CommandBox.Text ~= obj.Name) and CommandBox.Text or nil
    OutputSayer.Text = "Requiring module..."
    logOutput("MODULE: requiring " .. obj:GetFullName(), Color3.fromRGB(180, 100, 255))
    task.spawn(function()
        local ok, mod = pcall(require, obj)
        if ok then
            local modType = type(mod)
            if funcName and modType == "table" and type(mod[funcName]) == "function" then
                local ok2, result = pcall(mod[funcName])
                if ok2 then
                    OutputSayer.Text = "Module fn OK"
                    logOutput("MODULE:" .. obj.Name .. "." .. funcName .. "() => " .. tostring(result), Color3.fromRGB(180, 100, 255))
                else
                    OutputSayer.Text = "ERR (see log)"
                    logOutput("ERR MODULE fn '" .. funcName .. "': " .. tostring(result), Color3.fromRGB(255, 80, 80))
                end
            elseif funcName and modType == "table" and mod[funcName] == nil then
                OutputSayer.Text = "Fn not found"
                local keys = {}
                for k in pairs(mod) do table.insert(keys, tostring(k)) end
                logOutput("MODULE: '" .. funcName .. "' not found\nAvailable: " .. table.concat(keys, ", "), Color3.fromRGB(255, 180, 0))
            else
                OutputSayer.Text = "Required OK"
                if modType == "table" then
                    local keys = {}
                    for k in pairs(mod) do table.insert(keys, tostring(k)) end
                    logOutput("MODULE: " .. obj.Name .. " OK\nKeys: " .. table.concat(keys, ", "), Color3.fromRGB(180, 100, 255))
                else
                    logOutput("MODULE: " .. obj.Name .. " OK\nReturned: " .. modType, Color3.fromRGB(180, 100, 255))
                end
            end
        else
            OutputSayer.Text = "ERR require"
            logOutput("ERR require " .. obj.Name .. ":\n  " .. tostring(mod), Color3.fromRGB(255, 80, 80))
        end
    end)

elseif obj:IsA("LocalScript") then
    -- Try to enable it (if disabled), then clone+run it in our own context
    OutputSayer.Text = "LocalScript: enabling..."
    logOutput("SCRIPT: targeting LocalScript " .. obj:GetFullName(), Color3.fromRGB(180, 100, 255))
    pcall(function()
        obj.Disabled = false
    end)
    -- Try loadstring if the executor exposes Source
    task.spawn(function()
        local ok, src = pcall(function() return obj.Source end)
        if ok and src and src ~= "" then
            local fn, err = loadstring(src)
            if fn then
                local ok2, result = pcall(fn)
                if ok2 then
                    OutputSayer.Text = "Script ran OK"
                    logOutput("SCRIPT RAN: " .. obj.Name .. " => " .. tostring(result), Color3.fromRGB(180, 100, 255))
                else
                    OutputSayer.Text = "Script ERR"
                    logOutput("ERR SCRIPT RUN " .. obj.Name .. ":\n  " .. tostring(result), Color3.fromRGB(255, 80, 80))
                end
            else
                OutputSayer.Text = "Enabled (no Source)"
                logOutput("SCRIPT: enabled " .. obj.Name .. " (loadstring ERR: " .. tostring(err) .. ")", Color3.fromRGB(180, 100, 255))
            end
        else
            OutputSayer.Text = "Enabled (Source N/A)"
            logOutput("SCRIPT: enabled " .. obj.Name .. " — Source not accessible", Color3.fromRGB(180, 100, 255))
        end
    end)

elseif obj:IsA("Script") then
    -- Server scripts can't be run from client — log info and try to read what we can
    OutputSayer.Text = "Server Script (info only)"
    logOutput("SERVER SCRIPT: " .. obj:GetFullName() .. "\nClass=" .. obj.ClassName .. "  Disabled=" .. tostring(obj.Disabled), Color3.fromRGB(180, 100, 255))
    pcall(function()
        local ok, src = pcall(function() return obj.Source end)
        if ok and src and src ~= "" then
            logOutput("SERVER SCRIPT SRC (first 200):\n" .. src:sub(1, 200), Color3.fromRGB(150, 80, 200))
        end
    end)

else
    -- UTILITY / unknown — try every generic trick
    OutputSayer.Text = "UTILITY: probing..."
    logOutput("UTILITY: " .. obj.Name .. "  Class=" .. obj.ClassName .. "\nPATH=" .. obj:GetFullName(), Color3.fromRGB(255, 80, 80))
    pcall(function()
        -- If it has a Value property, set it
        if obj:IsA("ValueBase") then
            obj.Value = val
            logOutput("UTILITY SET .Value = " .. tostring(val), Color3.fromRGB(255, 120, 0))
            OutputSayer.Text = "Value set"
            return
        end
        -- If it's a BasePart, log its position and try to touch-trigger
        if obj:IsA("BasePart") then
            local p = obj.Position
            logOutput("UTILITY PART pos=" .. string.format("(%.1f,%.1f,%.1f)", p.X, p.Y, p.Z), Color3.fromRGB(255, 80, 80))
            -- Try to teleport player to it
            local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if root and CommandBox.Text:lower() == "tp" then
                root.CFrame = obj.CFrame + Vector3.new(0, 3, 0)
                logOutput("UTILITY TP → " .. obj.Name, Color3.fromRGB(57, 255, 20))
                OutputSayer.Text = "TP'd to part"
            else
                OutputSayer.Text = "Part logged (type tp to teleport)"
            end
            return
        end
        -- Generic: try to call it as a function
        if type(obj) == "function" then
            local ok2, r = pcall(obj)
            logOutput("UTILITY CALL: " .. obj.Name .. " => " .. tostring(r), Color3.fromRGB(255, 80, 80))
            OutputSayer.Text = ok2 and "Called OK" or "Call ERR"
            return
        end
        logOutput("UTILITY: no executable action for class " .. obj.ClassName, Color3.fromRGB(120, 120, 120))
        OutputSayer.Text = "Logged (no action)"
    end)
end
end


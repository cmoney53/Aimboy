-- Parse "val1, val2, val3" string into a typed args table
local function parseMultiArgs(text)
local args = {}
local count = 0
for token in (text .. ","):gmatch("([^,]*),") do
    token = token:match("^%s*(.-)%s*$")
    count = count + 1
    if token == "nil" or token == "" then
        args[count] = nil
    elseif token == "true" then
        args[count] = true
    elseif token == "false" then
        args[count] = false
    elseif token:lower() == "player" or token:lower() == "localplayer" then
        args[count] = Player
    elseif tonumber(token) then
        args[count] = tonumber(token)
    elseif (token:sub(1,1) == '"' and token:sub(-1) == '"') or (token:sub(1,1) == "'" and token:sub(-1) == "'") then
        args[count] = token:sub(2, -2)
    else
        args[count] = token
    end
end
return args, count
end


-- 6. ARGUMENT SNIFFER ENGINE
local sniffedLogs = {}
local MAX_LOGS = 50

local function formatArgs(...)
    local args = {...}
    local str = ""
    for i, v in pairs(args) do
        str = str .. "[" .. i .. "]: " .. tostring(v) .. " (" .. typeof(v) .. ") "
    end
    return str == "" and "No Arguments" or str
end

-- Hooking the Remote Methods
local oldFireServer
oldFireServer = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if (method == "FireServer" or method == "InvokeServer") and not checkcaller() then
        local logEntry = {
            Name = self.Name,
            Args = formatArgs(...),
            Time = os.date("%X"),
            Type = method,
            Path = self:GetFullName()
        }
        table.insert(sniffedLogs, 1, logEntry)
        if #sniffedLogs > MAX_LOGS then table.remove(sniffedLogs) end
    end
    return oldFireServer(self, ...)
end)


-- 6. SCANNER LOGIC
local clickConn = nil

local function addEntry(obj, typeTag)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 30)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = " [" .. typeTag .. "] " .. obj.Name
    b.TextColor3 = Color3.fromRGB(57, 255, 20)
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        Side.Visible = true
        SideTitle.Text = obj.Name
        CommandInput.Text = obj.Name -- Loads name into box for editing
        
        -- Generate logical outcomes based on item
        if typeTag == "GUI" then
            OutcomeLabel.Text = "TARGET: " .. obj.Name .. "\nTYPE: Interface\nOUTCOME: Forcing local visibility. Note: May reveal developer-only buttons if executed."
        else
            OutcomeLabel.Text = "TARGET: " .. obj.Name .. "\nTYPE: Remote Bridge\nOUTCOME: Attempting server-side trigger. Status: Waiting for user to edit box and hit Execute."
        end

        -- Execution logic
        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
            if typeTag == "GUI" then
                obj.Enabled = not obj.Enabled
            end
            ExecuteBtn.Text = "FIRED"
            task.wait(1)
            ExecuteBtn.Text = "EXECUTE"
        end)
    end)
end

-- Recursive Search for every Remote/GUI
local function runScan()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    
    -- Scan Interfaces
    for _, g in pairs(PlayerGui:GetChildren()) do
        if g:IsA("ScreenGui") and g ~= ScreenGui then addEntry(g, "GUI") end
    end
    
    -- Scan Command Bridges (Remotes)
    local function scan(parent)
        for _, child in pairs(parent:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                addEntry(child, "CMD")
            elseif not child:IsA("Player") then
                pcall(function() scan(child) end)
            end
        end
    end
    scan(ReplicatedStorage)
    scan(workspace)
end

-- Filter & Refresh
Search:GetPropertyChangedSignal("Text"):Connect(function()

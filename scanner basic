-- FIRE ALL helpers
local function ultraFireAll(registry, label)
    local count = 0
    local val = tonumber(CommandBox.Text) or CommandBox.Text
    for _, e in ipairs(registry) do
        pcall(function()
            if e.obj and e.obj.Parent then
                if e.obj:IsA("RemoteEvent") then e.obj:FireServer(val) count=count+1
                elseif e.obj:IsA("BindableEvent") then e.obj:Fire(val) count=count+1 end
            end
        end)
        task.wait()
    end
    logOutput("ULTRA FIRE ALL " .. label .. ": " .. count .. " fired", Color3.fromRGB(255,60,255))
    OutputSayer.Text = "ULTRA: fired " .. count
end


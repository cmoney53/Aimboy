local function scan()
    for _, v in pairs(PlayerGui:GetChildren()) do if v:IsA("ScreenGui") and v ~= ScreenGui then createEntry(v, "GUI", "Guis") end end
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do 
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then createEntry(v, "REMOTE", "Remotes") end 
    end
    for _, v in pairs(Player:GetDescendants()) do if v:IsA("ValueBase") then createEntry(v, "DATA", "Data") end end
end

task.spawn(function()
    while task.wait(5) do scan() end
end)

-- 6. CORE SCANNER LOGIC
local clickConn = nil
local function addEntry(obj, typeTag)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = " [" .. typeTag .. "] " .. obj.Name
    
    -- Visual Coding
    if typeTag:find("GUI") then b.TextColor3 = Color3.fromRGB(0, 200, 255)
    elseif typeTag == "DATA" then b.TextColor3 = Color3.fromRGB(255, 180, 0)
    elseif typeTag == "CMD" then b.TextColor3 = Color3.fromRGB(57, 255, 20)
    else b.TextColor3 = Color3.fromRGB(200, 200, 200) end
    
    b.TextXAlignment = Enum.TextXAlignment.Left
    b.Parent = Scroll
    Instance.new("UICorner", b)

    -- Persistent Search during Refresh
    if not b.Text:lower():find(Search.Text:lower()) then b.Visible = false end

    b.MouseButton1Click:Connect(function()
        Side.Visible = true
        OutputSayer.Text = "Status: Selected " .. obj.Name
        CommandBox.Text = tostring(obj:IsA("ValueBase") and obj.Value or obj.Name)
        InfoLabel.Text = "NAME: " .. obj.Name .. "\nTYPE: " .. typeTag .. "\nPATH: " .. obj:GetFullName()

        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
            local val = tonumber(CommandBox.Text) or CommandBox.Text
            
            if typeTag:find("GUI") then
                obj.Enabled = true
                -- Deep Force Toggle
                for _, v in pairs(obj:GetDescendants()) do
                    pcall(function() 
                        if v:IsA("Frame") or v:IsA("ScrollingFrame") or v:IsA("CanvasGroup") then 
                            v.Visible = true 
                        end 
                    end)
                end
                OutputSayer.Text = "Status: GUI Force-Opened"
            elseif typeTag == "DATA" then
                obj.Value = val
                OutputSayer.Text = "Status: Local Data Applied"
            elseif obj:IsA("RemoteEvent") then
                obj:FireServer(val)
                OutputSayer.Text = "Status: Remote Event Fired"
            elseif obj:IsA("RemoteFunction") then
                OutputSayer.Text = "Status: Invoking Function..."
                task.spawn(function() obj:InvokeServer(val) end)
            end
        end)
    end)
end


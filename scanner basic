-- 8. ADVANCED SEARCH
-- Prefix filters: re: gui: data: mod: bind: admin: script:
-- Searches name, full path, and typeTag simultaneously
local TYPE_PREFIXES = {
    re      = function(t) return t:find("remote") end,
    gui     = function(t) return t:find("gui") end,
    data    = function(t) return t:find("data") end,
    mod     = function(t) return t:find("module") end,
    bind    = function(t) return t:find("bind") end,
    admin   = function(t) return t:find("admin") end,
    script  = function(t) return t:find("script") end,
    money   = function(t) return t:find("money") end,
    util    = function(t) return t:find("util") end,
}

Search:GetPropertyChangedSignal("Text"):Connect(function()
local raw = Search.Text
local f   = raw:lower()
local isSearching = f ~= ""

-- Parse optional prefix filter (e.g. "re:give" → filter=re, text=give)
local filterFn  = nil
local textQuery = f
local prefix, rest = f:match("^(%a+):(.*)")
if prefix and TYPE_PREFIXES[prefix] then
    filterFn  = TYPE_PREFIXES[prefix]
    textQuery = rest:match("^%s*(.-)%s*$")  -- trim whitespace
end

local totalVisible = 0
local catHasMatch = {}

-- Evaluate each tracked entry button
for b, meta in pairs(entryMeta) do
    if b and b.Parent then
        local show = true
        if isSearching then
            -- 1. Type filter
            if filterFn and not filterFn(meta.typeTag) then
                show = false
            end
            -- 2. Text filter (name OR path OR typeTag all searched)
            if show and textQuery ~= "" then
                show = meta.name:find(textQuery, 1, true) ~= nil
                    or meta.path:find(textQuery, 1, true) ~= nil
                    or meta.typeTag:find(textQuery, 1, true) ~= nil
            end
        else
            -- Restore natural collapsed state
            show = not collapsedCategories[meta.category]
        end
        b.Visible = show
        if show then
            totalVisible = totalVisible + 1
            catHasMatch[meta.category] = true
        end
    end
end

-- Show/hide category headers based on whether they have visible results
for cat, hdr in pairs(categoryHeaders) do
    if isSearching then
        hdr.Visible = catHasMatch[cat] == true
    else
        hdr.Visible = true
    end
end

-- Update result count label
if isSearching then
    local suffix = prefix and (" [" .. prefix .. ":]") or ""
    ResultCountLabel.Text = totalVisible .. " result" .. (totalVisible == 1 and "" or "s") .. suffix
    ResultCountLabel.TextColor3 = totalVisible > 0
        and Color3.fromRGB(57, 255, 20)
        or  Color3.fromRGB(255, 80, 80)
else
    ResultCountLabel.Text = ""
end
end)

-- Run initial scan in background so it doesn't freeze the game on load
task.spawn(function()
    runOmniScan()
    -- Auto-rescan every 60 seconds instead of 6 (way less lag)
    while true do
        task.wait(60)
        runOmniScan()
    end
end)


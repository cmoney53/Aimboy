-- 6. DYNAMIC LOGIC
local clickConn = nil

local function addEntry(name, typeTag, outcome, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    btn.Text = " [" .. typeTag .. "] " .. name
    btn.TextColor3 = Color3.fromRGB(57, 255, 20)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = Scroll
    Instance.new("UICorner", btn)

    -- Apply search filter immediately to new items
    local filter = SearchBox.Text:lower()
    btn.Visible = btn.Text:lower():find(filter) ~= nil

    btn.MouseButton1Click:Connect(function()
        SidePanel.Visible = true
        SideTitle.Text = name
        OutcomeLabel.Text = "Possible Outcome:\n" .. outcome
        if clickConn then clickConn:Disconnect() end
        clickConn = ExecuteBtn.MouseButton1Click:Connect(callback)
    end)
end


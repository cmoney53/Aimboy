-- Parses comma-separated arg string into a typed table
-- Supports: numbers, true/false, nil, quoted strings, plain strings
local function parseArgs(text)
    local args = {}
    local trimmed = text:match("^%s*(.-)%s*$")
    if trimmed == "" then return args end
    for part in (trimmed .. ","):gmatch("([^,]*),") do
        local s = part:match("^%s*(.-)%s*$")
        local num = tonumber(s)
        if num then
            table.insert(args, num)
        elseif s:lower() == "true" then
            table.insert(args, true)
        elseif s:lower() == "false" then
            table.insert(args, false)
        elseif s:lower() == "nil" then
            -- skip nil args (table.unpack will handle gaps)
        else
            local quoted = s:match('^"(.*)"$') or s:match("^'(.*)'$")
            table.insert(args, quoted or s)
        end
    end
    return args
end


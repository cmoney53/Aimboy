blastBtn.MouseButton1Click:Connect(function()
    local targetName = rankTargetBox.Text
    local target = Player
    if targetName ~= "" then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Name:lower():find(targetName:lower()) then target = plr break end
        end
    end
    local rankVal = tonumber(rankValueBox.Text) or 255
    local combos  = rankBlastCombos(target, rankVal)
    local hitCount = 0

    blastStatus.Text = "Scanning for admin remotes..."
    blastBtn.BackgroundColor3 = Color3.fromRGB(120, 50, 0)

    task.spawn(function()
        -- Collect all remote-looking objects from every service
        local candidates = {}
        local seen = {}
        local function collectRemotes(parent)
            local ok, ch = pcall(function() return parent:GetChildren() end)
            if not ok then return end
            for _, child in ipairs(ch) do
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    local id = ""
                    pcall(function() id = child:GetFullName() end)
                    if not seen[id] then
                        seen[id] = true
                        local low = child.Name:lower()
                        local isAdmin = false
                        for _, pat in ipairs(rankGiverPatterns[1]) do
                            if low:find(pat, 1, true) then isAdmin = true break end
                        end
                        if isAdmin then table.insert(candidates, child) end
                    end
                end
                if not child:IsA("Terrain") and not child:IsA("Player") then
                    pcall(function() collectRemotes(child) end)
                end
            end
        end
        for _, svcName in ipairs({"ReplicatedStorage","ReplicatedFirst","Workspace","Players","StarterGui","Chat","CoreGui"}) do
            pcall(function()
                local svc = game:GetService(svcName)
                if svc then collectRemotes(svc) end
            end)
        end

        blastStatus.Text = "Found " .. #candidates .. " targets — blasting..."
        logOutput("RANK BLAST: " .. #candidates .. " candidates found", Color3.fromRGB(255,130,0))

        for _, remote in ipairs(candidates) do
            for _, combo in ipairs(combos) do
                pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(table.unpack(combo))
                        hitCount = hitCount + 1
                    elseif remote:IsA("RemoteFunction") then
                        remote:InvokeServer(table.unpack(combo))
                        hitCount = hitCount + 1
                    end
                end)
                task.wait(0.02)
            end
            logOutput("RANK BLAST: fired " .. remote.Name .. " (" .. #combos .. " combos)",
                Color3.fromRGB(255,130,0))
        end
        blastStatus.Text = "Done — " .. hitCount .. " shots fired at " .. #candidates .. " remotes"
        blastBtn.BackgroundColor3 = Color3.fromRGB(80,30,0)
        logOutput("RANK BLAST COMPLETE — total shots: " .. hitCount, Color3.fromRGB(255,130,0))
    end)
end)


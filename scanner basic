local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

-- Main Frame
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 400, 0, 300)
main.Position = UDim2.new(0.3, 0, 0.3, 0)
main.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
main.Active = true
main.Draggable = true

-- Rounded corners
local corner = Instance.new("UICorner", main)
corner.CornerRadius = UDim.new(0, 15)

-- Title bar
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "Admin Scanner UI (Your Game)"
title.BackgroundTransparency = 1

-- Close button
local close = Instance.new("TextButton", main)
close.Size = UDim2.new(0, 30, 0, 30)
close.Position = UDim2.new(1, -30, 0, 0)
close.Text = "X"

close.MouseButton1Click:Connect(function()
    gui:Destroy()
end)

-- Minimize button
local minimize = Instance.new("TextButton", main)
minimize.Size = UDim2.new(0, 30, 0, 30)
minimize.Position = UDim2.new(1, -60, 0, 0)
minimize.Text = "-"

local minimized = false
minimize.MouseButton1Click:Connect(function()
    minimized = not minimized
    for _, v in pairs(main:GetChildren()) do
        if v ~= title and v ~= close and v ~= minimize then
            v.Visible = not minimized
        end
    end
end)

-- Command List
local listFrame = Instance.new("Frame", main)
listFrame.Size = UDim2.new(0.4, 0, 1, -30)
listFrame.Position = UDim2.new(0, 0, 0, 30)

local layout = Instance.new("UIListLayout", listFrame)

-- Side Panel
local side = Instance.new("Frame", main)
side.Size = UDim2.new(0.6, 0, 1, -30)
side.Position = UDim2.new(0.4, 0, 0, 30)

-- Command Info
local info = Instance.new("TextLabel", side)
info.Size = UDim2.new(1, 0, 0.4, 0)
info.Text = "Select a command..."

-- Input box
local input = Instance.new("TextBox", side)
input.Size = UDim2.new(1, -10, 0, 30)
input.Position = UDim2.new(0, 5, 0.5, 0)
input.PlaceholderText = "Enter parameter (e.g. player name)"

-- Execute button
local execute = Instance.new("TextButton", side)
execute.Size = UDim2.new(1, -10, 0, 40)
execute.Position = UDim2.new(0, 5, 0.7, 0)
execute.Text = "Execute"

-- Fake commands (you define these)
local commands = {
    {
        name = "Spawn Character",
        description = "Spawns a character by name",
        action = function(param)
            if param == "" then
                return "No character spawned. Enter a name."
            else
                return "Spawned character: " .. param
            end
        end
    },
    {
        name = "Give Tool",
        description = "Gives a tool",
        action = function(param)
            if param == "" then
                return "No tool given. Enter tool name."
            else
                return "Tool given: " .. param
            end
        end
    }
}

local selectedCommand = nil

-- Populate command list
for _, cmd in pairs(commands) do
    local btn = Instance.new("TextButton", listFrame)
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.Text = cmd.name

    btn.MouseButton1Click:Connect(function()
        selectedCommand = cmd
        info.Text = cmd.description
    end)
end

-- Execute logic
execute.MouseButton1Click:Connect(function()
    if selectedCommand then
        local result = selectedCommand.action(input.Text)
        info.Text = result
    end
end)

local function classifyRemote(name, fullPath)
    local low  = name:lower()
    local path = fullPath:lower()
    local ctx  = low .. " " .. path

    local isAdmin  = false
    local isMoney  = false
    local isScript = false
    local isServer = false
    local isPlayer = false
    local isStat   = false

    for _, k in ipairs(adminKeywords)     do if ctx:find(k,1,true) then isAdmin  = true break end end
    for _, k in ipairs(moneyDepthKeywords) do if ctx:find(k,1,true) then isMoney  = true break end end
    for _, k in ipairs(scriptRemoteKws)   do if ctx:find(k,1,true) then isScript = true break end end
    for _, k in ipairs(serverRemoteKws)   do if ctx:find(k,1,true) then isServer = true break end end
    for _, k in ipairs(playerRemoteKws)   do if ctx:find(k,1,true) then isPlayer = true break end end
    for _, k in ipairs(statGainKeywords)  do if ctx:find(k,1,true) then isStat   = true break end end

    return isAdmin, isMoney, isScript, isServer, isPlayer, isStat
end

local function registerRemote(child, id, baseTag)
    seenRemotes[id] = true
    totalFound = totalFound + 1
    local fullPath = ""
    pcall(function() fullPath = child:GetFullName() end)
    local isAdmin, isMoney, isScript, isServer, isPlayer, isStat =
        classifyRemote(child.Name, fullPath)

    -- Always add to ALL REMOTES and base Remotes list
    if canAddToCategory("ALL REMOTES") then addEntry(child, baseTag,           "ALL REMOTES")        end
    if canAddToCategory("Remotes")     then addEntry(child, baseTag,           "Remotes")            end
    -- Classified categories
    if isAdmin  and canAddToCategory("Admin Remotes")       then addEntry(child, "ADMIN:"  ..baseTag, "Admin Remotes")       end
    if isMoney  and canAddToCategory("Money/Depth Remotes") then addEntry(child, "MONEY:"  ..baseTag, "Money/Depth Remotes") end
    if isStat   and canAddToCategory("Stat Gain Remotes")   then addEntry(child, "STAT:"   ..baseTag, "Stat Gain Remotes")   end
    if isScript and canAddToCategory("Script Remotes")      then addEntry(child, "SCRIPT:" ..baseTag, "Script Remotes")      end
    if isServer and canAddToCategory("Server Remotes")      then addEntry(child, "SERVER:" ..baseTag, "Server Remotes")      end
    if isPlayer and canAddToCategory("Player Remotes")      then addEntry(child, "PLAYER:" ..baseTag, "Player Remotes")      end
end

local function heavyDeepScan(parent, depth)
    depth = depth or 0
    local ok, children = pcall(function() return parent:GetChildren() end)
    if not ok then return end

    for _, child in ipairs(children) do
        local id = ""
        pcall(function() id = child:GetFullName() end)
        if id == "" then id = tostring(child) end

        scanStepCount = scanStepCount + 1
        -- Yield every 5 objects — ultra-smooth, catches dynamic remotes mid-scan
        if scanStepCount % 5 == 0 then task.wait() end

        -- ── REMOTE EVENTS ──────────────────────────────────────────
        if child:IsA("RemoteEvent") then
            if not seenRemotes[id] then registerRemote(child, id, "RE") end

        -- ── REMOTE FUNCTIONS ───────────────────────────────────────
        elseif child:IsA("RemoteFunction") then
            if not seenRemotes[id] then registerRemote(child, id, "RF") end

        -- ── BINDABLES ──────────────────────────────────────────────
        elseif child:IsA("BindableEvent") then
            if not seenRemotes[id] then
                seenRemotes[id] = true
                totalFound = totalFound + 1
                if canAddToCategory("Bindables")    then addEntry(child, "BIND:E",   "Bindables")    end
                if canAddToCategory("ALL REMOTES")  then addEntry(child, "BIND:E",   "ALL REMOTES")  end
                if canAddToCategory("Remotes")      then addEntry(child, "BINDABLE", "Remotes")      end
            end
        elseif child:IsA("BindableFunction") then
            if not seenRemotes[id] then
                seenRemotes[id] = true
                totalFound = totalFound + 1
                if canAddToCategory("Bindables")    then addEntry(child, "BIND:F",   "Bindables")    end
                if canAddToCategory("ALL REMOTES")  then addEntry(child, "BIND:F",   "ALL REMOTES")  end
                if canAddToCategory("Remotes")      then addEntry(child, "BINDABLE", "Remotes")      end
            end
        end

        -- ── OBJECTVALUE POINTING TO A REMOTE ───────────────────────
        if child:IsA("ObjectValue") then
            pcall(function()
                local ref = child.Value
                if ref and (ref:IsA("RemoteEvent") or ref:IsA("RemoteFunction")) then
                    local refId = ""
                    pcall(function() refId = ref:GetFullName() end)
                    if not seenRemotes[refId] then
                        registerRemote(ref, refId, "REF:" .. (ref:IsA("RemoteEvent") and "RE" or "RF"))
                    end
                end
            end)
        end

        -- ── SCRIPTS ────────────────────────────────────────────────
        local isScriptObj = child:IsA("LocalScript") or child:IsA("ModuleScript") or child:IsA("Script")
        if isScriptObj then
            local low = child.Name:lower()
            local matchesKeyword = false
            for _, k in ipairs(adminKeywords) do if low:find(k,1,true) then matchesKeyword=true break end end
            if matchesKeyword and canAddToCategory("Scripts") then
                addEntry(child, "SCRIPT[" .. child.ClassName .. "]", "Scripts")
            elseif canAddToCategory("Scripts") then
                -- Add all scripts (open category to see them all)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, 0, 0, 32)
                b.BackgroundColor3 = Color3.fromRGB(20, 10, 30)
                b.Text = "  ↳ [" .. child.ClassName .. "] " .. child.Name
                b.TextColor3 = Color3.fromRGB(180, 100, 255)
                b.TextXAlignment = Enum.TextXAlignment.Left
                b.Parent = Scroll
                Instance.new("UICorner", b)
                local scriptPath = ""
                pcall(function() scriptPath = child:GetFullName():lower() end)
                entryMeta[b] = {
                    name     = child.Name:lower(),
                    typeTag  = child.ClassName:lower(),
                    path     = scriptPath,
                    category = "Scripts",
                }
                categoryEntries["Scripts"] = categoryEntries["Scripts"] or {}
                table.insert(categoryEntries["Scripts"], b)
                b.Visible = not collapsedCategories["Scripts"]
                b.MouseButton1Click:Connect(function()
                    stopSpam()
                    selectedObj = child
                    selectedTypeTag = child.ClassName:upper()
                    OutputSayer.Text = "Selected: " .. child.Name
                    CommandBox.Text = child.Name
                    InfoLabel.Text = "NAME: " .. child.Name .. "\nTYPE: " .. child.ClassName .. "\nPATH: " .. child:GetFullName()
                    Main.ClipsDescendants = false
                    Side.Visible = true
                    if clickConn then clickConn:Disconnect() end
                    clickConn = ExecuteBtn.MouseButton1Click:Connect(function()
                        doExecute(selectedObj, selectedTypeTag)
                    end)
                end)
            end
            -- ── ULTRA SOURCE MINING: mine ALL keyword lists from script source ──
            pcall(function()
                local src = child.Source or ""
                if src and src ~= "" then
                    local allKwLists = {adminKeywords, moneyDepthKeywords, statGainKeywords, scriptRemoteKws, serverRemoteKws, playerRemoteKws}
                    local mineSvcs = {"ReplicatedStorage","ReplicatedFirst","Workspace","ServerStorage","ServerScriptService","StarterGui","StarterPack","StarterPlayer","Players","Lighting","SoundService","Teams","Chat","LocalizationService","TestService"}
                    for quoted in src:gmatch('["\']([A-Za-z0-9_%.]+)["\']') do
                        local ql = quoted:lower()
                        local matched = false
                        for _, kwList in ipairs(allKwLists) do
                            if matched then break end
                            for _, k in ipairs(kwList) do
                                if ql:find(k,1,true) then matched = true break end
                            end
                        end
                        if matched then
                            pcall(function()
                                for _, svcName in ipairs(mineSvcs) do
                                    pcall(function()
                                        local svc = game:GetService(svcName)
                                        local found = svc and svc:FindFirstChild(quoted, true)
                                        if found and (found:IsA("RemoteEvent") or found:IsA("RemoteFunction")) then
                                            local fid = ""
                                            pcall(function() fid = found:GetFullName() end)
                                            if not seenRemotes[fid] then
                                                registerRemote(found, fid, "MINED")
                                                logOutput("MINED from " .. child.Name .. ": " .. found:GetFullName(), Color3.fromRGB(200, 100, 255))
                                            end
                                        end
                                    end)
                                end
                            end)
                        end
                    end
                    -- Also mine :WaitForChild, :FindFirstChild, :FindFirstChildOfClass patterns
                    for _, pat in ipairs({'WaitForChild%("([^"]+)"', "WaitForChild%('([^']+)'", 'FindFirstChild%("([^"]+)"', "FindFirstChild%('([^']+)'", 'FindFirstChildWhichIsA%("([^"]+)"', "FindFirstChildOfClass%('([^']+)'"}) do
                        for name in src:gmatch(pat) do
                            pcall(function()
                                for _, svcName in ipairs(mineSvcs) do
                                    pcall(function()
                                        local svc = game:GetService(svcName)
                                        local found = svc and svc:FindFirstChild(name, true)
                                        if found and (found:IsA("RemoteEvent") or found:IsA("RemoteFunction")) then
                                            local fid = ""
                                            pcall(function() fid = found:GetFullName() end)
                                            if not seenRemotes[fid] then
                                                registerRemote(found, fid, "PATTERN")
                                                logOutput("PATTERN MINED: " .. found:GetFullName(), Color3.fromRGB(200, 150, 255))
                                            end
                                        end
                                    end)
                                end
                            end)
                        end
                    end
                end
            end)
        end

        -- ── UTILITY NON-REMOTES matching keywords ──────────────────
        if not child:IsA("RemoteEvent") and not child:IsA("RemoteFunction")
            and not child:IsA("BindableEvent") and not child:IsA("BindableFunction") then
            local low = child.Name:lower()
            for _, key in pairs(adminKeywords) do
                if low:find(key, 1, true) then
                    if child:IsA("ValueBase") then
                        if canAddToCategory("Admin Remotes") then addEntry(child, "ADMIN DATA", "Admin Remotes") end
                    elseif not isScriptObj then
                        if canAddToCategory("Utilities") then addEntry(child, "UTILITY[" .. child.ClassName .. "]", "Utilities") end
                    end
                    break
                end
            end
        end

        -- ── RECURSE (no depth limit, skip only Terrain) ────────────
        if not child:IsA("Terrain") then
            pcall(function() heavyDeepScan(child, depth + 1) end)
        end
    end
end

-- helper: register any remote/bindable found in a catch-all pass
local function catchRemote(child, phaseLabel)
    if not (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")
        or child:IsA("BindableEvent") or child:IsA("BindableFunction")) then return end
    local id = ""
    pcall(function() id = child:GetFullName() end)
    if id == "" or seenRemotes[id] then return end
    local baseTag = child:IsA("RemoteEvent") and "RE"
        or child:IsA("RemoteFunction")  and "RF"
        or child:IsA("BindableEvent")   and "BIND:E" or "BIND:F"
    if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
        registerRemote(child, id, phaseLabel..":"..baseTag)
    else
        seenRemotes[id] = true; totalFound = totalFound + 1
        if canAddToCategory("Bindables")   then addEntry(child, phaseLabel..":"..baseTag, "Bindables")   end
        if canAddToCategory("ALL REMOTES") then addEntry(child, phaseLabel..":"..baseTag, "ALL REMOTES") end
    end
    logOutput(phaseLabel.." FOUND: "..id, Color3.fromRGB(57,200,20))
end

